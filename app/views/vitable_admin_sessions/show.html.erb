<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.18fr_0.82fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@admin_sessions.latest_packet&.status || "pending") %>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Employer-bound tokens</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Benefits administration</span>
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800 ring-1 ring-inset ring-emerald-200">Billing</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Employer admin sessions</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Prepare and issue short-lived Vitable access sessions bound to <%= @admin_sessions.employer&.name || "your employer portfolio" %>, so benefits and billing administration widgets can launch without exposing API credentials.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate admin packet", generate_vitable_admin_sessions_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Issue admin session", issue_vitable_admin_session_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Employer sync", vitable_employer_provisioning_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Administration docs", @admin_sessions.administration_docs_url, target: "_blank", rel: "noopener", class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Latest admin packet</p>
        <% if @admin_sessions.latest_packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @admin_sessions.latest_packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@admin_sessions.latest_packet.generated_at) %> ago by <%= operator_name(@admin_sessions.latest_packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Widgets</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@admin_sessions.latest_packet.widget_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@admin_sessions.latest_packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Token endpoint</p>
            <p class="mt-2 break-all font-mono text-xs text-slate-600"><%= @admin_sessions.latest_packet.endpoint %></p>
            <p class="mt-2 break-all font-mono text-xs text-slate-400"><%= @admin_sessions.latest_packet.remote_employer_id.presence || "Remote employer ID required" %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate a packet to validate employer-bound widget readiness.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
    <% @admin_sessions.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold text-slate-950">
          <%= metric.format == "number" ? compact_number(metric.value) : metric.value %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Launch preflight</h2>
        <p class="text-sm text-slate-500">Checks that decide whether employer-bound admin token issuance can proceed.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @admin_sessions.preflight_checks.each do |check| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= check.label %></p>
              <p class="mt-1 break-words text-sm text-slate-500"><%= check.detail %></p>
            </div>
            <%= status_pill(check.status) %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Token attempts</h2>
        <p class="text-sm text-slate-500">Employer-bound token requests recorded without storing token secrets.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @admin_sessions.token_runs.each do |sync| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= sync.operation.humanize %> <%= sync.resource_type %></p>
              <p class="mt-1 text-sm text-slate-500"><%= sync.started_at&.strftime("%b %-d, %I:%M %p") || "n/a" %></p>
              <% if sync.error_message.present? %>
                <p class="mt-1 break-words text-xs text-rose-600"><%= sync.error_message %></p>
              <% end %>
            </div>
            <%= status_pill(sync.status) %>
          </div>
        <% end %>
        <% if @admin_sessions.token_runs.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No employer admin token attempts have been recorded yet.</p>
        <% end %>
      </div>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Embedded admin widgets</h2>
        <p class="text-sm text-slate-500">Employer-facing Vitable administration surfaces covered by the employer-bound token.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @admin_sessions.widgets.each do |widget| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= widget.component %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= widget.name %></h3>
              </div>
              <%= status_pill(widget.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= widget.description %></p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Session issuance activity</h2>
        <p class="text-sm text-slate-500">Request log evidence for employer-bound admin sessions.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @admin_sessions.request_logs.each do |log| %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= log.method %> <%= log.path %></p>
                <p class="mt-1 text-sm text-slate-500"><%= log.operation %> · <%= log.duration_ms || 0 %>ms</p>
                <% if log.error_class.present? %>
                  <p class="mt-1 break-all text-xs text-rose-600"><%= log.error_class %></p>
                <% end %>
              </div>
              <%= status_pill(log.error_class.present? ? "failed" : "ready") %>
            </div>
          </div>
        <% end %>
        <% if @admin_sessions.request_logs.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No admin session requests have been sent yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</section>
