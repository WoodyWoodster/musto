<% current_program = @training.current_program %>
<% latest_packet = @training.latest_packet %>

<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.22fr_0.78fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(current_program&.status || "draft") %>
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800 ring-1 ring-inset ring-emerald-200">Compliance training</span>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Certificates and audit evidence</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Compliance training center</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Launch required employee training, monitor overdue assignments, complete certification tasks, and package audit evidence for <%= @training.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Launch training", launch_training_program_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Generate audit packet", generate_training_audit_packet_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Compliance cases", compliance_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Documents", documents_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-300">Current program</p>
        <% if current_program.present? %>
          <div class="mt-6 flex flex-wrap items-center gap-2">
            <%= status_pill(current_program.status) %>
            <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold text-slate-200 ring-1 ring-inset ring-white/10"><%= current_program.category.humanize %></span>
          </div>
          <p class="mt-4 text-3xl font-semibold tracking-tight"><%= current_program.title %></p>
          <p class="mt-2 text-sm leading-6 text-slate-300"><%= current_program.description.presence || "Required training program." %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Required</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(current_program.required_count) %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Complete</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(current_program.completed_count) %></p>
            </div>
          </div>
          <div class="mt-5 h-2 overflow-hidden rounded-full bg-white/10">
            <div class="h-full rounded-full bg-emerald-300" style="width: <%= current_program.completion_rate %>%"></div>
          </div>
          <div class="mt-5 rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Due date</p>
            <p class="mt-2 text-lg font-semibold"><%= current_program.due_on.strftime("%b %-d, %Y") %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">No program</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Launch training to assign required courses to active employees.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @training.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950"><%= metric.format == "percent" ? "#{compact_number(metric.value)}%" : compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Training portfolio</h2>
        <p class="text-sm text-slate-500">Required courses, completion rates, overdue counts, and launch state.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @training.programs.each do |program| %>
          <article class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="text-base font-semibold text-slate-950"><%= program.title %></h3>
                  <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= program.cadence.humanize %></span>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= program.category.humanize %> · <%= program.audience.humanize %> · due <%= program.due_on.strftime("%b %-d") %></p>
              </div>
              <%= status_pill(program.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= program.description.presence || "No description provided." %></p>
            <div class="mt-5 h-2 overflow-hidden rounded-full bg-slate-100">
              <div class="h-full rounded-full bg-slate-950" style="width: <%= program.completion_rate %>%"></div>
            </div>
            <div class="mt-4 grid grid-cols-4 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Required</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(program.required_count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Done</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(program.completed_count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Open</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(program.open_count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Late</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(program.overdue_count) %></p>
              </div>
            </div>
          </article>
        <% end %>
        <% if @training.programs.empty? %>
          <div class="p-5 text-sm text-slate-600">No training programs exist yet.</div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Training issues</h2>
        <p class="text-sm text-slate-500">Launch, completion, certificate, and audit blockers that need attention.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @training.issues.each do |issue| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= issue.owner %> · <%= issue.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.title %></h3>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.detail %></p>
            <div class="mt-4 flex items-center justify-between gap-3">
              <span class="rounded-md bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700"><%= compact_number(issue.count) %> records</span>
              <%= link_to "Open workflow", issue.action_path, class: "text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="flex flex-col gap-2 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Assignment roster</h2>
        <p class="text-sm text-slate-500">Employee completion status, due dates, certificates, and one-click completion actions.</p>
      </div>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= compact_number(@training.completable_assignments.count) %> actionable</span>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Program</th>
            <th class="px-5 py-3">Due</th>
            <th class="px-5 py-3">Score</th>
            <th class="px-5 py-3">Readiness</th>
            <th class="px-5 py-3">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @training.assignments.each do |assignment| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to assignment.employee_name, employee_path(assignment.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= assignment.employee_title.presence || "Role pending" %> · <%= assignment.department_name || "Unassigned" %></p>
              </td>
              <td class="px-5 py-4 text-slate-600">
                <%= assignment.program_title %>
                <p class="mt-1 text-xs text-slate-500"><%= assignment.location_name || "No location" %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= assignment.due_on.strftime("%b %-d, %Y") %></td>
              <td class="px-5 py-4">
                <span class="rounded-md bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700"><%= assignment.score || "Pending" %></span>
              </td>
              <td class="px-5 py-4">
                <%= status_pill(assignment.readiness_status) %>
                <p class="mt-1 max-w-52 text-xs text-slate-500"><%= assignment.readiness_reason %></p>
              </td>
              <td class="px-5 py-4">
                <% if assignment.completable? %>
                  <%= button_to "Complete", complete_training_assignment_path(assignment.id), method: :post, params: { completed_by: "ops_console", score: 96 }, class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <% else %>
                  <span class="text-xs font-semibold text-slate-400">No action</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @training.assignments.empty? %>
            <tr>
              <td colspan="6" class="px-5 py-5 text-sm text-slate-600">No assignments exist yet. Launch training to create employee assignments.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Audit packet ledger</h2>
      <p class="text-sm text-slate-500">Certificate-ready assignments included in the latest audit packet and holdbacks still waiting on completion or evidence.</p>
    </div>
    <% if latest_packet.present? %>
      <div class="grid gap-4 border-b border-slate-100 bg-slate-50 px-5 py-4 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <%= status_pill(latest_packet.status) %>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-200">Training audit packet</span>
          </div>
          <p class="mt-3 break-words text-sm font-semibold text-slate-950"><%= latest_packet.batch_id %></p>
          <p class="mt-1 text-sm text-slate-500">Requested by <%= latest_packet.requested_by.presence || "ops_console" %></p>
        </div>
        <div class="grid grid-cols-4 gap-2 text-center">
          <div class="rounded-md bg-white px-2 py-3 ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Records</p>
            <p class="mt-1 font-semibold text-slate-950"><%= compact_number(latest_packet.assignment_count) %></p>
          </div>
          <div class="rounded-md bg-white px-2 py-3 ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">People</p>
            <p class="mt-1 font-semibold text-slate-950"><%= compact_number(latest_packet.employee_count) %></p>
          </div>
          <div class="rounded-md bg-white px-2 py-3 ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Holdbacks</p>
            <p class="mt-1 font-semibold text-slate-950"><%= compact_number(latest_packet.holdback_count) %></p>
          </div>
          <div class="rounded-md bg-white px-2 py-3 ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Avg.</p>
            <p class="mt-1 font-semibold text-slate-950"><%= latest_packet.average_score %></p>
          </div>
        </div>
      </div>

      <div class="grid divide-y divide-slate-100 xl:grid-cols-2 xl:divide-x xl:divide-y-0">
        <div>
          <div class="border-b border-slate-100 px-5 py-3">
            <h3 class="text-sm font-semibold text-slate-950">Included certificates</h3>
          </div>
          <div class="divide-y divide-slate-100">
            <% @training.audit_lines.each do |line| %>
              <div class="p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-950"><%= line.employee_name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= line.program_title %> · <%= line.category.humanize %></p>
                  </div>
                  <%= status_pill(line.status) %>
                </div>
                <div class="mt-3 flex flex-wrap gap-2">
                  <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">Score <%= line.score || "n/a" %></span>
                  <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= line.certificate_id || "Certificate pending" %></span>
                </div>
              </div>
            <% end %>
            <% if @training.audit_lines.empty? %>
              <div class="p-5 text-sm text-slate-600">No certificates were included in the latest packet.</div>
            <% end %>
          </div>
        </div>

        <div>
          <div class="border-b border-slate-100 px-5 py-3">
            <h3 class="text-sm font-semibold text-slate-950">Holdbacks</h3>
          </div>
          <div class="divide-y divide-slate-100">
            <% @training.audit_holdbacks.each do |holdback| %>
              <div class="p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-950"><%= holdback.employee_name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= holdback.program_title %></p>
                  </div>
                  <%= status_pill(holdback.status) %>
                </div>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
              </div>
            <% end %>
            <% if @training.audit_holdbacks.empty? %>
              <div class="p-5 text-sm text-slate-600">No holdbacks in the latest packet.</div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="p-5 text-sm text-slate-600">No audit packet has been generated yet.</div>
    <% end %>
  </section>
</section>
