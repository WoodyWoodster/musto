<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.25fr_0.75fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@time_off.pending_requests.any? ? "needs_review" : "ready") %>
          <span class="rounded-full bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-700 ring-1 ring-inset ring-violet-200">PTO operations</span>
        </div>
        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Time off</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Review PTO requests, monitor policy utilization, forecast coverage gaps, and keep payroll-impacting leave decisions current for <%= @time_off.employer&.name || "your employer portfolio" %>.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "PTO ledger", time_off_accruals_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Compliance", compliance_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Workforce", workforce_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Payroll", payroll_path, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Review queue</p>
        <p class="mt-6 text-5xl font-semibold"><%= @time_off.pending_requests.count %></p>
        <p class="mt-2 text-sm leading-6 text-slate-600">requests waiting on a payroll-aware decision</p>
        <div class="mt-6 grid grid-cols-2 gap-3">
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Upcoming</p>
            <p class="mt-2 text-2xl font-semibold"><%= @time_off.calendar_blocks.count %></p>
          </div>
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">At risk</p>
            <p class="mt-2 text-2xl font-semibold"><%= @time_off.risk_balances.count %></p>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @time_off.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold text-slate-950"><%= number_with_precision(metric.value, precision: 1, strip_insignificant_zeros: true) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Request review</h2>
        <p class="text-sm text-slate-500">Approve or deny leave requests before payroll and coverage planning lock.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @time_off.requests.first(10).each do |request| %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <p class="font-semibold text-slate-950"><%= request.employee_name %></p>
                  <%= status_pill(request.status) %>
                </div>
                <p class="mt-1 text-sm text-slate-500">
                  <%= request.policy_name %> · <%= request.starts_on.strftime("%b %-d") %> - <%= request.ends_on.strftime("%b %-d") %> ·
                  <%= number_with_precision(request.hours, precision: 1, strip_insignificant_zeros: true) %>h across <%= request.duration_days %> day<%= "s" unless request.duration_days == 1 %>
                </p>
                <p class="mt-2 text-sm text-slate-600"><%= request.reason.presence || "No reason provided" %></p>
              </div>
            </div>
            <% if request.requested? %>
              <div class="mt-4 flex flex-wrap gap-2">
                <%= button_to "Approve", approve_time_off_request_path(request.id), method: :post, params: { return_to: "time_off" }, class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <%= button_to "Deny", deny_time_off_request_path(request.id), method: :post, params: { return_to: "time_off" }, class: "rounded-md border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
              </div>
            <% elsif request.reviewed_at.present? %>
              <p class="mt-3 text-xs font-semibold uppercase text-slate-400">Reviewed <%= time_ago_in_words(request.reviewed_at) %> ago</p>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Employee balances</h2>
        <p class="text-sm text-slate-500">Projected balance risk from configured policies and current-year requests.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Employee</th>
              <th class="px-5 py-3">Allowance</th>
              <th class="px-5 py-3">Approved</th>
              <th class="px-5 py-3">Pending</th>
              <th class="px-5 py-3">Remaining</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @time_off.balances.each do |balance| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4">
                  <%= link_to balance.employee_name, employee_path(balance.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                  <p class="text-xs text-slate-500"><%= balance.department_name || "Unassigned" %> · <%= balance.work_location_name || "No location" %></p>
                </td>
                <td class="px-5 py-4 text-slate-600"><%= number_with_precision(balance.allowance_hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
                <td class="px-5 py-4 text-slate-600">
                  <%= number_with_precision(balance.approved_hours, precision: 1, strip_insignificant_zeros: true) %>h
                  <p class="text-xs text-slate-500"><%= balance.utilization_percent %>% used</p>
                </td>
                <td class="px-5 py-4 text-slate-600"><%= number_with_precision(balance.pending_hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
                <td class="px-5 py-4 font-semibold text-slate-950"><%= number_with_precision(balance.remaining_hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
                <td class="px-5 py-4"><%= status_pill(balance.status) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Policy utilization</h2>
        <p class="text-sm text-slate-500">Accrual setup, carryover, and demand by time-off policy.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @time_off.policies.each do |policy| %>
          <div class="px-5 py-4">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <div class="flex flex-wrap items-center gap-2">
                  <p class="font-semibold text-slate-950"><%= policy.name %></p>
                  <%= status_pill(policy.status) %>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= policy.accrual_method.humanize %> · <%= policy.paid_label %> · <%= policy.request_count %> requests</p>
              </div>
              <p class="text-right text-sm font-semibold text-slate-950"><%= policy.utilization_percent %>% used</p>
            </div>
            <div class="mt-4 h-2 overflow-hidden rounded-full bg-slate-100">
              <div class="h-full rounded-full bg-violet-500" style="width: <%= [policy.utilization_percent, 100].min %>%"></div>
            </div>
            <dl class="mt-4 grid grid-cols-3 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <dt class="text-xs text-slate-500">Annual</dt>
                <dd class="mt-1 text-lg font-semibold text-slate-950"><%= number_with_precision(policy.annual_hours, precision: 1, strip_insignificant_zeros: true) %>h</dd>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <dt class="text-xs text-slate-500">Carry</dt>
                <dd class="mt-1 text-lg font-semibold text-slate-950"><%= number_with_precision(policy.carryover_hours, precision: 1, strip_insignificant_zeros: true) %>h</dd>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <dt class="text-xs text-slate-500">Pending</dt>
                <dd class="mt-1 text-lg font-semibold text-slate-950"><%= number_with_precision(policy.pending_hours, precision: 1, strip_insignificant_zeros: true) %>h</dd>
              </div>
            </dl>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Upcoming leave calendar</h2>
        <p class="text-sm text-slate-500">Future approved and requested leave that can affect scheduling and payroll.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @time_off.calendar_blocks.each do |block| %>
          <div class="grid gap-4 px-5 py-4 sm:grid-cols-[1fr_auto] sm:items-center">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <p class="font-semibold text-slate-950"><%= block.employee_name %></p>
                <%= status_pill(block.status) %>
              </div>
              <p class="mt-1 text-sm text-slate-500"><%= block.policy_name %> · <%= block.date_range %> · <%= number_with_precision(block.hours, precision: 1, strip_insignificant_zeros: true) %>h</p>
            </div>
            <span class="rounded-md bg-slate-100 px-3 py-2 text-sm font-semibold text-slate-700"><%= block.starts_on.strftime("%a") %></span>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</section>
