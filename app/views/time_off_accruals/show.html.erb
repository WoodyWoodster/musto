<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.16fr_0.84fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-700 ring-1 ring-inset ring-violet-200">PTO accrual ledger</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-700 ring-1 ring-inset ring-cyan-200">Payroll packet</span>
          <%= status_pill(@accruals.packet&.status || "pending") %>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">PTO accrual and payroll ledger</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Generate monthly PTO credits, approve pending accruals, reconcile approved usage, and prepare a payroll-ready time-off packet for <%= @accruals.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate monthly accruals", generate_time_off_accruals_path, method: :post, params: { period_start_on: Date.current.beginning_of_month.iso8601, requested_by: "Payroll Team" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Generate payroll packet", generate_time_off_accrual_payroll_packet_path, method: :post, params: { requested_by: "Payroll Team" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Time off", time_off_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Payroll", payroll_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Latest PTO packet</p>
        <% if @accruals.packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @accruals.packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@accruals.packet.generated_at) %> ago by <%= operator_name(@accruals.packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Lines</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@accruals.packet.line_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@accruals.packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Hours</p>
            <p class="mt-2 text-2xl font-semibold"><%= number_with_precision(@accruals.packet.accrual_hours, precision: 1, strip_insignificant_zeros: true) %> credited</p>
            <p class="mt-2 text-xs text-slate-400"><%= number_with_precision(@accruals.packet.usage_hours, precision: 1, strip_insignificant_zeros: true) %> approved PTO usage hours</p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate a payroll packet after approving accrual credits and reviewing PTO usage.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @accruals.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold text-slate-950">
          <% if metric.format == "hours" %>
            <%= number_with_precision(metric.value, precision: 1, strip_insignificant_zeros: true) %>h
          <% elsif metric.format == "number" %>
            <%= compact_number(metric.value) %>
          <% else %>
            <%= metric.value %>
          <% end %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Employee PTO balances</h2>
        <p class="text-sm text-slate-500">Approved accruals, pending credits, approved usage, and remaining PTO by employee.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Employee</th>
              <th class="px-5 py-3">Approved</th>
              <th class="px-5 py-3">Pending</th>
              <th class="px-5 py-3">Used</th>
              <th class="px-5 py-3">Remaining</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @accruals.balances.each do |balance| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4">
                  <%= link_to balance.employee_name, employee_path(balance.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                  <p class="mt-1 text-xs text-slate-500"><%= balance.department_name %> · <%= compact_number(balance.policy_count) %> policies</p>
                </td>
                <td class="px-5 py-4 text-slate-600"><%= number_with_precision(balance.approved_accrual_hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
                <td class="px-5 py-4 text-slate-600"><%= number_with_precision(balance.pending_accrual_hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
                <td class="px-5 py-4 text-slate-600"><%= number_with_precision(balance.approved_usage_hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
                <td class="px-5 py-4 font-semibold text-slate-950"><%= number_with_precision(balance.remaining_hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
                <td class="px-5 py-4"><%= status_pill(balance.status) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Payroll readiness issues</h2>
        <p class="text-sm text-slate-500">Accrual and request problems that need review before the payroll export.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @accruals.issues.first(12).each do |issue| %>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= issue.reason_code.humanize %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.employee_name %></h3>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
            <p class="mt-2 text-xs text-slate-400"><%= issue.policy_name %></p>
          </div>
        <% end %>
        <% if @accruals.issues.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No PTO payroll readiness issues are open.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Accrual ledger</h2>
      <p class="text-sm text-slate-500">Generated credits and adjustments waiting for payroll-aware approval.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Policy</th>
            <th class="px-5 py-3">Period</th>
            <th class="px-5 py-3">Hours</th>
            <th class="px-5 py-3">Source</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @accruals.accruals.each do |accrual| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to accrual.employee_name, employee_path(accrual.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= accrual.accrual_type.humanize %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= accrual.policy_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= accrual.period_label %></td>
              <td class="px-5 py-4 font-semibold text-slate-950"><%= number_with_precision(accrual.hours, precision: 1, strip_insignificant_zeros: true) %>h</td>
              <td class="px-5 py-4 text-slate-600"><%= accrual.source.humanize %></td>
              <td class="px-5 py-4"><%= status_pill(accrual.status) %></td>
              <td class="px-5 py-4">
                <% if accrual.pending? %>
                  <%= button_to "Approve", approve_time_off_accrual_path(accrual.id), method: :post, params: { approved_by: "Payroll Team" }, class: "rounded-md bg-emerald-600 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <% elsif accrual.approved_at.present? %>
                  <p class="text-xs font-semibold uppercase text-slate-400">Approved <%= time_ago_in_words(accrual.approved_at) %> ago</p>
                <% else %>
                  <p class="text-xs text-slate-400">No action</p>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Payroll packet lines</h2>
        <p class="text-sm text-slate-500">Approved PTO credits and usage from the latest generated packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @accruals.packet_lines.each do |line| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= line.employee_name %></p>
              <p class="mt-1 text-sm text-slate-500"><%= line.policy_name %> · <%= line.line_type.humanize %> · <%= line.payroll_action.humanize %></p>
            </div>
            <div class="text-right">
              <%= status_pill(line.status) %>
              <p class="mt-2 text-sm font-semibold text-slate-950"><%= number_with_precision(line.hours, precision: 1, strip_insignificant_zeros: true) %>h</p>
            </div>
          </div>
        <% end %>
        <% if @accruals.packet_lines.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">Generate a payroll packet after approving accruals.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet holdbacks</h2>
        <p class="text-sm text-slate-500">Persisted blockers from the latest PTO payroll packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @accruals.packet_holdbacks.each do |issue| %>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= issue.employee_name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= issue.reason %></p>
              </div>
              <%= status_pill(issue.status) %>
            </div>
          </div>
        <% end %>
        <% if @accruals.packet_holdbacks.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No packet holdbacks have been captured yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</section>
