<section class="space-y-7">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase text-slate-500">Employers</p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-950">Employer portfolio</h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">A multi-employer operating layer for benefits, payroll, compliance, and Vitable organization routing.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Company setup", company_setup_path, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      <%= link_to "Back to command", root_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
    </div>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Employer</th>
            <th class="px-5 py-3">Organization</th>
            <th class="px-5 py-3">People</th>
            <th class="px-5 py-3">Benefits</th>
            <th class="px-5 py-3">Payroll</th>
            <th class="px-5 py-3">Compliance</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @employers.each do |employer| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to employer.name, employer_path(employer.id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= employer.legal_name.presence || "Legal entity pending" %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= employer.organization_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= employer.employee_count %></td>
              <td class="px-5 py-4 text-slate-600"><%= employer.accepted_enrollment_count %>/<%= employer.enrollment_count %> accepted</td>
              <td class="px-5 py-4 text-slate-600"><%= employer.payroll_run_count %> runs</td>
              <td class="px-5 py-4 text-slate-600"><%= employer.open_compliance_case_count %> open</td>
              <td class="px-5 py-4"><%= status_pill(employer.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
