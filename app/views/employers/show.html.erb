<section class="space-y-7">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <%= link_to "Back to employers", employers_path, class: "text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
      <p class="mt-5 text-sm font-semibold uppercase tracking-[0.18em] text-slate-500"><%= @employer.organization_name %></p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950"><%= @employer.name %></h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600"><%= @employer.legal_name.presence || "Legal entity pending" %> · EIN <%= @employer.ein.presence || "pending" %> · Vitable ID <%= @employer.vitable_id.presence || "not synced" %></p>
    </div>
    <%= status_pill(@employer.status) %>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <% [
      ["Employees", @employer.employee_count],
      ["Departments", @employer.department_count],
      ["Benefit plans", @employer.benefit_plan_count],
      ["Open cases", @employer.open_compliance_case_count]
    ].each do |label, value| %>
      <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <p class="text-sm text-slate-500"><%= label %></p>
        <p class="mt-3 text-3xl font-semibold"><%= value %></p>
      </div>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Roster snapshot</h2>
        <p class="text-sm text-slate-500">Department, location, and compensation coverage.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @employer.employees.each do |employee| %>
          <div class="grid gap-3 px-5 py-4 md:grid-cols-[1fr_auto]">
            <div>
              <%= link_to employee.full_name, employee_path(employee.id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
              <p class="mt-1 text-sm text-slate-500"><%= employee.title.presence || "Role pending" %> · <%= employee.department_name || "Unassigned" %> · <%= employee.work_location_name || "Unassigned" %></p>
            </div>
            <div class="text-left md:text-right">
              <p class="font-semibold text-slate-950"><%= money_cents(employee.compensation_cents) %></p>
              <p class="text-xs text-slate-500"><%= employee.pay_type.humanize %></p>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Benefits catalog</h2>
        <p class="text-sm text-slate-500">Plan availability and monthly premiums.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @employer.benefit_plans.each do |plan| %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-semibold text-slate-950"><%= plan.name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= plan.category.humanize %> · <%= plan.carrier %></p>
              </div>
              <%= status_pill(plan.status) %>
            </div>
            <p class="mt-3 text-sm font-semibold text-slate-950"><%= money_cents(plan.monthly_premium_cents) %>/mo</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</section>
