<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.25fr_0.75fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@expenses.reviewable_expenses.any? || @expenses.approved_expenses.any? ? "needs_review" : "ready") %>
          <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold text-orange-800 ring-1 ring-inset ring-orange-200">Employee expenses</span>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Payroll reimbursement</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Expenses and reimbursements</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Review employee-paid expenses, enforce receipt policy, approve reimbursements, and generate payroll-ready reimbursement batches for <%= @expenses.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Payroll", payroll_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Reports", reports_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Workforce", workforce_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= button_to "Generate reimbursement batch", generate_expense_reimbursement_batch_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-orange-300">Latest reimbursement batch</p>
        <% if @expenses.latest_batch.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @expenses.latest_batch.batch_id %></p>
          <p class="mt-3 text-sm text-slate-300">Generated <%= time_ago_in_words(@expenses.latest_batch.generated_at) %> ago by <%= @expenses.latest_batch.requested_by %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Lines</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@expenses.latest_batch.reimbursement_count) %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@expenses.latest_batch.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Batch total</p>
            <p class="mt-2 text-2xl font-semibold"><%= money_cents(@expenses.latest_batch.total_cents) %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">No batch</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Approve reimbursable expenses before generating the next payroll batch.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @expenses.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950"><%= metric.format == "money" ? money_cents(metric.value) : compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Expense review queue</h2>
        <p class="text-sm text-slate-500">Approve receipt-ready reimbursements before they reach payroll.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @expenses.expenses.first(10).each do |expense| %>
          <div class="px-5 py-4">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <%= link_to expense.employee_name, employee_path(expense.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                  <%= status_pill(expense.status) %>
                  <%= status_pill(expense.receipt_status) %>
                  <%= status_pill(expense.policy_status) %>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= expense.department_name %> · <%= expense.location_name %> · <%= expense.category.humanize %></p>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  <%= expense.merchant %> · <%= expense.incurred_on.strftime("%b %-d, %Y") %>
                  <% if expense.description.present? %>
                    · <%= expense.description %>
                  <% end %>
                </p>
              </div>
              <p class="text-right text-lg font-semibold text-slate-950"><%= money_cents(expense.amount_cents) %></p>
            </div>

            <% if expense.submitted? %>
              <div class="mt-4 flex flex-wrap items-center gap-2">
                <% if expense.policy_ready? %>
                  <%= button_to "Approve", approve_expense_path(expense.id), method: :post, params: { reviewed_by: "ops_console" }, class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <% else %>
                  <span class="rounded-md border border-amber-200 bg-amber-50 px-3 py-2 text-sm font-semibold text-amber-800"><%= expense.block_reason %></span>
                <% end %>
              </div>
            <% end %>
          </div>
        <% end %>

        <% if @expenses.expenses.empty? %>
          <div class="p-5">
            <p class="font-semibold text-slate-950">No expenses</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Submitted, approved, rejected, and reimbursed expenses will appear here once employees submit receipts.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Policy exceptions</h2>
        <p class="text-sm text-slate-500">Receipt, policy, approval, and payroll batching work remaining.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @expenses.policy_items.each do |item| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= item.owner %> · <%= item.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= item.title %></h3>
              </div>
              <%= status_pill(item.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= item.detail %></p>
            <div class="mt-4 grid grid-cols-2 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Count</p>
                <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(item.count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Amount</p>
                <p class="mt-1 text-lg font-semibold text-slate-950"><%= money_cents(item.amount_cents) %></p>
              </div>
            </div>
            <%= link_to "Open workflow", item.action_path, class: "mt-4 inline-flex text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Expense ledger</h2>
      <p class="text-sm text-slate-500">Employee expense records with policy, receipt, department, and payment context.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Merchant</th>
            <th class="px-5 py-3">Category</th>
            <th class="px-5 py-3">Receipt</th>
            <th class="px-5 py-3">Method</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @expenses.expenses.each do |expense| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to expense.employee_name, employee_path(expense.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= expense.department_name %></p>
              </td>
              <td class="px-5 py-4">
                <p class="font-medium text-slate-950"><%= expense.merchant %></p>
                <p class="mt-1 text-xs text-slate-500"><%= expense.incurred_on.strftime("%b %-d, %Y") %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= expense.category.humanize %></td>
              <td class="px-5 py-4"><%= status_pill(expense.receipt_status) %></td>
              <td class="px-5 py-4 text-slate-600"><%= expense.payment_method.humanize %></td>
              <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(expense.amount_cents) %></td>
              <td class="px-5 py-4"><%= status_pill(expense.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Reimbursement batch ledger</h2>
      <p class="text-sm text-slate-500">Approved reimbursement lines and policy holdbacks from the latest generated batch.</p>
    </div>
    <% if @expenses.latest_batch.present? %>
      <div class="grid divide-y divide-slate-100 lg:grid-cols-[1fr_0.9fr] lg:divide-x lg:divide-y-0">
        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Included reimbursements</p>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-sm">
              <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-5 py-3">Employee</th>
                  <th class="px-5 py-3">Merchant</th>
                  <th class="px-5 py-3">Method</th>
                  <th class="px-5 py-3">Amount</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% @expenses.batch_lines.each do |line| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-5 py-4">
                      <p class="font-semibold text-slate-950"><%= line.employee_name %></p>
                      <p class="mt-1 text-xs text-slate-500"><%= line.department_name %></p>
                    </td>
                    <td class="px-5 py-4">
                      <p class="text-slate-600"><%= line.merchant %></p>
                      <p class="mt-1 text-xs text-slate-500"><%= line.incurred_on.strftime("%b %-d, %Y") %> · <%= line.category.humanize %></p>
                    </td>
                    <td class="px-5 py-4 text-slate-600"><%= line.payment_method.humanize %></td>
                    <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(line.amount_cents) %></td>
                  </tr>
                <% end %>
                <% if @expenses.batch_lines.empty? %>
                  <tr>
                    <td colspan="4" class="px-5 py-5 text-sm text-slate-600">No approved reimbursements were included.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Holdbacks</p>
          </div>
          <div class="divide-y divide-slate-100">
            <% @expenses.batch_holdbacks.each do |holdback| %>
              <div class="p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-950"><%= holdback.employee_name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= holdback.merchant %> · <%= holdback.category.humanize %></p>
                  </div>
                  <%= status_pill(holdback.status) %>
                </div>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
                <p class="mt-3 text-sm font-semibold text-slate-950"><%= money_cents(holdback.amount_cents) %></p>
              </div>
            <% end %>
            <% if @expenses.batch_holdbacks.empty? %>
              <div class="p-5">
                <p class="font-semibold text-slate-950">No holdbacks</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">All approved expenses were included in the latest reimbursement batch.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="p-5">
        <p class="font-semibold text-slate-950">No generated batch</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">The next generated reimbursement batch will list included payroll lines and holdbacks here.</p>
      </div>
    <% end %>
  </section>
</section>
