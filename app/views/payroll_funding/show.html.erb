<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.25fr_0.75fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@funding.funding_issues.any? { |issue| issue.status != "ready" } ? "needs_review" : "ready") %>
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800 ring-1 ring-inset ring-emerald-200">Direct deposit</span>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">ACH funding</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Payroll funding and direct deposit</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Verify company funding, clear employee bank account prenotes, and generate a payroll ACH batch for <%= @funding.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Payroll", payroll_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <% if @funding.payroll_run.present? %>
            <%= link_to "Open current run", payroll_run_path(@funding.payroll_run.id), class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <% end %>
          <%= link_to "Reports", reports_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= button_to "Generate ACH batch", generate_payroll_funding_batch_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-emerald-300">Latest ACH batch</p>
        <% if @funding.latest_batch.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @funding.latest_batch.batch_id %></p>
          <p class="mt-3 text-sm text-slate-300">Generated <%= time_ago_in_words(@funding.latest_batch.generated_at) %> ago by <%= @funding.latest_batch.requested_by %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Credits</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@funding.latest_batch.credit_count) %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@funding.latest_batch.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Debit total</p>
            <p class="mt-2 text-2xl font-semibold"><%= money_cents(@funding.latest_batch.total_cents) %></p>
            <p class="mt-1 text-xs text-slate-400"><%= @funding.latest_batch.debit_account_name || "Funding account pending" %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">No batch</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Generate ACH funding after bank account checks clear.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @funding.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950"><%= metric.format == "money" ? money_cents(metric.value) : compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Bank readiness</h2>
        <p class="text-sm text-slate-500">Company funding source and current payroll exposure.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @funding.employer_accounts.each do |account| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= account.name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= account.institution_name %> · <%= account.account_type.humanize %> ending <%= account.account_last4 %></p>
              </div>
              <%= status_pill(account.status) %>
            </div>
            <dl class="mt-4 grid grid-cols-2 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <dt class="text-xs text-slate-500">Routing</dt>
                <dd class="mt-1 text-lg font-semibold text-slate-950">****<%= account.routing_number_last4 %></dd>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <dt class="text-xs text-slate-500">Method</dt>
                <dd class="mt-1 text-lg font-semibold text-slate-950"><%= account.verification_method.humanize %></dd>
              </div>
            </dl>
          </div>
        <% end %>
        <% if @funding.employer_accounts.empty? %>
          <div class="p-5">
            <p class="font-semibold text-slate-950">No employer bank account</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Add a verified company funding source before generating ACH payroll batches.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Payroll funding issues</h2>
        <p class="text-sm text-slate-500">Items blocking ACH debit and direct deposit credits.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @funding.funding_issues.each do |issue| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= issue.owner %> · <%= issue.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.title %></h3>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.detail %></p>
            <div class="mt-4 grid grid-cols-2 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Count</p>
                <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(issue.count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Exposure</p>
                <p class="mt-1 text-lg font-semibold text-slate-950"><%= money_cents(issue.amount_cents) %></p>
              </div>
            </div>
            <%= link_to "Open workflow", issue.action_path, class: "mt-4 inline-flex text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Direct deposit review</h2>
      <p class="text-sm text-slate-500">Employee bank accounts, prenote states, and payroll credit readiness.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Account</th>
            <th class="px-5 py-3">Allocation</th>
            <th class="px-5 py-3">Verification</th>
            <th class="px-5 py-3">Readiness</th>
            <th class="px-5 py-3">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @funding.employee_accounts.each do |account| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to account.employee_name, employee_path(account.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= account.department_name %> · <%= account.location_name %></p>
              </td>
              <td class="px-5 py-4">
                <p class="font-medium text-slate-950"><%= account.nickname %></p>
                <p class="mt-1 text-xs text-slate-500"><%= account.institution_name %> · <%= account.account_type.humanize %> ending <%= account.account_last4 %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= account.allocation_type.humanize %> · <%= account.allocation_value %><%= account.allocation_type == "percent" ? "%" : "" %></td>
              <td class="px-5 py-4"><%= status_pill(account.status) %></td>
              <td class="px-5 py-4"><%= status_pill(account.readiness_status) %></td>
              <td class="px-5 py-4">
                <% if account.reviewable? %>
                  <%= button_to "Verify", verify_employee_bank_account_path(account.id), method: :post, params: { reviewed_by: "ops_console" }, class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <% else %>
                  <span class="text-sm font-medium text-slate-500"><%= account.verified? ? "Verified" : "No action" %></span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">ACH batch ledger</h2>
      <p class="text-sm text-slate-500">Direct deposit credits and employee holdbacks from the latest payroll funding batch.</p>
    </div>
    <% if @funding.latest_batch.present? %>
      <div class="grid divide-y divide-slate-100 lg:grid-cols-[1fr_0.9fr] lg:divide-x lg:divide-y-0">
        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">ACH credits</p>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-sm">
              <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-5 py-3">Employee</th>
                  <th class="px-5 py-3">Destination</th>
                  <th class="px-5 py-3">Trace</th>
                  <th class="px-5 py-3">Amount</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% @funding.batch_credits.each do |credit| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-5 py-4 font-semibold text-slate-950"><%= credit.employee_name %></td>
                    <td class="px-5 py-4 text-slate-600"><%= credit.institution_name %> ending <%= credit.account_last4 %></td>
                    <td class="px-5 py-4 font-mono text-xs text-slate-500"><%= credit.trace_code %></td>
                    <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(credit.amount_cents) %></td>
                  </tr>
                <% end %>
                <% if @funding.batch_credits.empty? %>
                  <tr>
                    <td colspan="4" class="px-5 py-5 text-sm text-slate-600">No ACH credits were included.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Holdbacks</p>
          </div>
          <div class="divide-y divide-slate-100">
            <% @funding.batch_holdbacks.each do |holdback| %>
              <div class="p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-950"><%= holdback.employee_name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= money_cents(holdback.amount_cents) %> held out of ACH credits</p>
                  </div>
                  <%= status_pill(holdback.status) %>
                </div>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
              </div>
            <% end %>
            <% if @funding.batch_holdbacks.empty? %>
              <div class="p-5">
                <p class="font-semibold text-slate-950">No holdbacks</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">All current payroll lines were included in ACH funding.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="p-5">
        <p class="font-semibold text-slate-950">No generated ACH batch</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">The next generated batch will show direct deposit credits and holdbacks here.</p>
      </div>
    <% end %>
  </section>
</section>
