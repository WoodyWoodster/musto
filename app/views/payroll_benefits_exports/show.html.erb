<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.15fr_0.85fr]">
      <div class="p-6 lg:p-8">
        <%= link_to "Back to payroll run", payroll_run_path(@export.payroll_run.id), class: "text-sm font-semibold text-indigo-700 hover:text-indigo-900" %>
        <div class="mt-5 flex flex-wrap items-center gap-2">
          <%= status_pill(@export.generated? ? @export.batch.fetch("status", "ready") : "pending") %>
          <%= status_pill(@export.payroll_run.status) %>
        </div>
        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Benefits deduction export</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Package ready Vitable benefit deductions for payroll close. The export stores a manifest on the payroll run while preserving deduction readiness for reconciliation.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <%= button_to "Generate export manifest", generate_payroll_run_benefits_export_path(@export.payroll_run.id), method: :post, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= link_to "Reconcile deductions", benefits_reconciliation_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-indigo-300">Export identity</p>
        <div class="mt-6 space-y-5">
          <div>
            <p class="text-sm text-slate-300">Batch</p>
            <p class="mt-1 break-all font-mono text-sm font-semibold"><%= @export.batch_id %></p>
          </div>
          <div class="h-px bg-white/10"></div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-sm text-slate-300">Employer</p>
              <p class="mt-1 font-semibold"><%= @export.employer_name %></p>
            </div>
            <div>
              <p class="text-sm text-slate-300">Pay date</p>
              <p class="mt-1 font-semibold"><%= @export.payroll_run.pay_date.strftime("%b %-d, %Y") %></p>
            </div>
          </div>
          <div class="rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Generated</p>
            <p class="mt-2 text-sm font-semibold text-white"><%= @export.generated_at&.strftime("%b %-d, %I:%M %p") || "Not yet" %></p>
            <p class="mt-1 text-sm text-slate-300"><%= @export.organization_name %></p>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <% @export.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <%= status_pill(metric.status) %>
        </div>
        <p class="mt-4 break-words text-2xl font-semibold tracking-tight text-slate-950">
          <%= metric.label == "Export total" ? money_cents(metric.value) : metric.value %>
        </p>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Export preflight</h2>
        <p class="text-sm text-slate-500">Checks before the deduction manifest is handed to the benefits provider workflow.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @export.preflight_checks.each do |check| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= check.label %></p>
              <p class="mt-1 break-words text-sm text-slate-500"><%= check.detail %></p>
            </div>
            <%= status_pill(check.status) %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-slate-950 shadow-sm">
      <div class="border-b border-white/10 px-5 py-4">
        <h2 class="text-base font-semibold text-white">Manifest payload</h2>
        <p class="text-sm text-slate-400">Preview or generated export package stored on the payroll run.</p>
      </div>
      <pre class="overflow-x-auto p-5 text-xs leading-6 text-cyan-100"><%= JSON.pretty_generate(@export.payload) %></pre>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Included deduction lines</h2>
      <p class="text-sm text-slate-500">Ready, positive benefit deductions included in the export manifest.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Plan</th>
            <th class="px-5 py-3">Code</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @export.included_lines.each do |line| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4"><%= link_to line.employee_name, employee_path(line.employee_id), class: "font-semibold text-slate-950 hover:text-indigo-700" %></td>
              <td class="px-5 py-4 text-slate-600"><%= line.plan_name %></td>
              <td class="px-5 py-4 font-mono text-xs text-slate-600"><%= line.code %></td>
              <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(line.amount_cents) %></td>
              <td class="px-5 py-4"><%= status_pill(line.deduction_status) %></td>
            </tr>
          <% end %>
          <% if @export.included_lines.empty? %>
            <tr>
              <td colspan="5" class="px-5 py-5 text-sm text-slate-500">No ready benefit deductions are available for export.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Holdbacks</h2>
      <p class="text-sm text-slate-500">Deductions excluded from the manifest until enrollment or payroll status is ready.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Plan</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Reason</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @export.holdback_lines.each do |line| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4 font-medium text-slate-950"><%= line.employee_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= line.plan_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(line.amount_cents) %></td>
              <td class="px-5 py-4">
                <p class="font-medium text-slate-950"><%= line.issue %></p>
                <p class="mt-1 text-xs text-slate-500"><%= line.enrollment_status.humanize %> · <%= line.deduction_status.humanize %></p>
              </td>
            </tr>
          <% end %>
          <% if @export.holdback_lines.empty? %>
            <tr>
              <td colspan="4" class="px-5 py-5 text-sm text-slate-500">No deduction holdbacks.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
