<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.22fr_0.78fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@open_enrollment.active_campaign? ? "active" : "draft") %>
          <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-800 ring-1 ring-inset ring-blue-200">Open enrollment</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Vitable handoff</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Open enrollment command center</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Launch benefit election windows, track employee completion, resolve dependent blockers, and prepare Vitable eligibility handoffs for <%= @open_enrollment.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Benefits cockpit", benefits_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Eligibility sync", benefits_eligibility_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Billing", benefits_billing_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= button_to "Launch campaign", launch_open_enrollment_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Send reminders", send_open_enrollment_reminders_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-blue-300">Campaign window</p>
        <% if @open_enrollment.campaign.present? %>
          <p class="mt-6 text-3xl font-semibold tracking-tight"><%= @open_enrollment.campaign.plan_year %></p>
          <p class="mt-2 text-sm leading-6 text-slate-300"><%= @open_enrollment.campaign.name %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Starts</p>
              <p class="mt-2 text-sm font-semibold"><%= @open_enrollment.campaign.starts_on.strftime("%b %-d") %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Ends</p>
              <p class="mt-2 text-sm font-semibold"><%= @open_enrollment.campaign.ends_on.strftime("%b %-d") %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Invitations</p>
            <p class="mt-2 text-2xl font-semibold"><%= compact_number(@open_enrollment.campaign.invitation_count) %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">Not launched</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Launch the next plan-year campaign to create employee invitations.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @open_enrollment.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950"><%= compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Enrollment blockers</h2>
        <p class="text-sm text-slate-500">Campaign, election, dependent, and Vitable readiness work remaining.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @open_enrollment.issues.each do |issue| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= issue.owner %> · <%= issue.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.title %></h3>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.detail %></p>
            <div class="mt-4 flex items-center justify-between gap-3">
              <span class="rounded-md bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700"><%= compact_number(issue.count) %> records</span>
              <%= link_to "Open workflow", issue.action_path, class: "text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
            </div>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Plan readiness</h2>
        <p class="text-sm text-slate-500">Published benefits available for election and Vitable enrollment sync.</p>
      </div>
      <div class="grid divide-y divide-slate-100 lg:grid-cols-2 lg:divide-x lg:divide-y-0">
        <% @open_enrollment.plans.each do |plan| %>
          <article class="p-5">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-semibold text-slate-950"><%= plan.name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= plan.category.humanize %> · <%= plan.carrier.presence || "Carrier pending" %></p>
              </div>
              <%= status_pill(plan.status) %>
            </div>
            <div class="mt-5 grid grid-cols-3 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Premium</p>
                <p class="mt-1 font-semibold text-slate-950"><%= money_cents(plan.monthly_premium_cents) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Accepted</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(plan.accepted_count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Remote</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(plan.remote_pending_count) %></p>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Employee election queue</h2>
      <p class="text-sm text-slate-500">Invitation status, election progress, dependent blockers, and remote ID readiness by employee.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Invite</th>
            <th class="px-5 py-3">Elections</th>
            <th class="px-5 py-3">Dependents</th>
            <th class="px-5 py-3">Remote</th>
            <th class="px-5 py-3">Readiness</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @open_enrollment.invitations.each do |invitation| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to invitation.employee_name, employee_path(invitation.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= invitation.department_name || "Unassigned" %> · <%= invitation.location_name || "No location" %></p>
              </td>
              <td class="px-5 py-4">
                <%= status_pill(invitation.status) %>
                <p class="mt-1 text-xs text-slate-500">Due <%= invitation.due_on.strftime("%b %-d, %Y") %></p>
              </td>
              <td class="px-5 py-4 text-slate-600">
                <%= compact_number(invitation.accepted_enrollment_count) %> accepted
                <p class="mt-1 text-xs text-slate-500"><%= compact_number(invitation.pending_enrollment_count) %> pending · <%= compact_number(invitation.waived_enrollment_count) %> waived</p>
              </td>
              <td class="px-5 py-4"><%= status_pill(invitation.dependent_review_count.positive? ? "needs_review" : "ready") %></td>
              <td class="px-5 py-4"><%= status_pill(invitation.remote_pending_count.positive? ? "remote_pending" : "synced") %></td>
              <td class="px-5 py-4">
                <%= status_pill(invitation.readiness_status) %>
                <p class="mt-1 max-w-56 text-xs text-slate-500"><%= invitation.readiness_reason %></p>
              </td>
            </tr>
          <% end %>
          <% if @open_enrollment.invitations.empty? %>
            <tr>
              <td colspan="6" class="px-5 py-5 text-sm text-slate-600">No employee invitations exist yet. Launch the campaign to create the open enrollment queue.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Open enrollment batch ledger</h2>
      <p class="text-sm text-slate-500">Latest invitation or reminder batch generated for the campaign.</p>
    </div>
    <% if @open_enrollment.latest_batch.present? %>
      <div class="grid gap-4 border-b border-slate-100 bg-slate-50 px-5 py-4 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <%= status_pill(@open_enrollment.latest_batch.status) %>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-200"><%= @open_enrollment.latest_batch.batch_type.humanize %> batch</span>
          </div>
          <p class="mt-3 break-all font-mono text-sm font-semibold text-slate-950"><%= @open_enrollment.latest_batch.batch_id %></p>
          <p class="mt-2 text-sm text-slate-500">Generated <%= time_ago_in_words(@open_enrollment.latest_batch.generated_at) %> ago by <%= @open_enrollment.latest_batch.requested_by %></p>
        </div>
        <div class="grid grid-cols-3 gap-2 text-center">
          <div class="rounded-md bg-white px-3 py-3 shadow-sm ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Sent</p>
            <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(@open_enrollment.latest_batch.sent_count) %></p>
          </div>
          <div class="rounded-md bg-white px-3 py-3 shadow-sm ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Reminders</p>
            <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(@open_enrollment.latest_batch.reminder_count) %></p>
          </div>
          <div class="rounded-md bg-white px-3 py-3 shadow-sm ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Held</p>
            <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(@open_enrollment.latest_batch.holdback_count) %></p>
          </div>
        </div>
      </div>
      <div class="grid divide-y divide-slate-100 lg:grid-cols-[1fr_0.85fr] lg:divide-x lg:divide-y-0">
        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= @open_enrollment.latest_batch.batch_type.humanize %> lines</p>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-sm">
              <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                <tr>
                  <th class="px-5 py-3">Employee</th>
                  <th class="px-5 py-3">Due</th>
                  <th class="px-5 py-3">Sent</th>
                  <th class="px-5 py-3">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% @open_enrollment.batch_lines.each do |line| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-5 py-4 font-semibold text-slate-950"><%= line.employee_name %></td>
                    <td class="px-5 py-4 text-slate-600"><%= line.due_on.strftime("%b %-d, %Y") %></td>
                    <td class="px-5 py-4 text-slate-600"><%= (line.last_reminded_at || line.sent_at)&.strftime("%b %-d, %Y") || "Not sent" %></td>
                    <td class="px-5 py-4"><%= status_pill(line.status) %></td>
                  </tr>
                <% end %>
                <% if @open_enrollment.batch_lines.empty? %>
                  <tr>
                    <td colspan="4" class="px-5 py-5 text-sm text-slate-600">No invitation lines were included in this batch.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400">Holdbacks</p>
          </div>
          <div class="divide-y divide-slate-100">
            <% @open_enrollment.batch_holdbacks.each do |holdback| %>
              <div class="p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-950"><%= holdback.employee_name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= holdback.reason %></p>
                  </div>
                  <%= status_pill(holdback.status) %>
                </div>
              </div>
            <% end %>
            <% if @open_enrollment.batch_holdbacks.empty? %>
              <div class="p-5">
                <p class="font-semibold text-slate-950">No holdbacks</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">Every actionable employee invitation was included in the latest batch.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="p-5">
        <p class="font-semibold text-slate-950">No campaign batch</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Launch the campaign or send reminders to populate the latest batch ledger.</p>
      </div>
    <% end %>
  </section>
</section>
