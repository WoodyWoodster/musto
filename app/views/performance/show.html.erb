<% current_cycle = @performance.current_cycle %>
<% latest_batch = @performance.latest_batch %>

<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.2fr_0.8fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(current_cycle&.status || "draft") %>
          <span class="rounded-full bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-800 ring-1 ring-inset ring-violet-200">Review cycles</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Goals and calibration</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Performance management center</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Launch review cycles, track manager reviews, complete goals, and package calibration packets for <%= @performance.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Launch cycle", launch_performance_cycle_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Generate calibration packet", generate_performance_calibration_packet_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Workforce", workforce_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Compensation", compensation_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Current cycle</p>
        <% if current_cycle.present? %>
          <div class="mt-6 flex flex-wrap items-center gap-2">
            <%= status_pill(current_cycle.status) %>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-200"><%= current_cycle.review_type.humanize %></span>
          </div>
          <p class="mt-4 text-3xl font-semibold"><%= current_cycle.name %></p>
          <p class="mt-2 text-sm leading-6 text-slate-600"><%= current_cycle.period_start_on.strftime("%b %-d") %> - <%= current_cycle.period_end_on.strftime("%b %-d, %Y") %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Reviews</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(current_cycle.review_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Open</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(current_cycle.open_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Due date</p>
            <p class="mt-2 text-lg font-semibold"><%= current_cycle.due_on.strftime("%b %-d, %Y") %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No cycle</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Launch a review cycle to create manager review assignments.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @performance.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold text-slate-950"><%= compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Cycle portfolio</h2>
        <p class="text-sm text-slate-500">Review cycles, completion progress, calibration count, and launch status.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @performance.cycles.each do |cycle| %>
          <article class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <h3 class="text-base font-semibold text-slate-950"><%= cycle.name %></h3>
                  <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= cycle.review_type.humanize %></span>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= cycle.period_start_on.strftime("%b %-d") %> - <%= cycle.period_end_on.strftime("%b %-d, %Y") %> · due <%= cycle.due_on.strftime("%b %-d") %></p>
              </div>
              <%= status_pill(cycle.status) %>
            </div>
            <div class="mt-5 h-2 overflow-hidden rounded-full bg-slate-100">
              <% completion_width = cycle.review_count.zero? ? 0 : ((cycle.completed_count.to_f / cycle.review_count) * 100).round %>
              <div class="h-full rounded-full bg-slate-950" style="width: <%= completion_width %>%"></div>
            </div>
            <div class="mt-4 grid grid-cols-4 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Reviews</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(cycle.review_count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Open</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(cycle.open_count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Done</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(cycle.completed_count) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Calib.</p>
                <p class="mt-1 font-semibold text-slate-950"><%= compact_number(cycle.calibration_count) %></p>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Performance issues</h2>
        <p class="text-sm text-slate-500">Cycle, review, reviewer, and goal blockers that need attention.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @performance.issues.each do |issue| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= issue.owner %> · <%= issue.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.title %></h3>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.detail %></p>
            <div class="mt-4 flex items-center justify-between gap-3">
              <span class="rounded-md bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700"><%= compact_number(issue.count) %> records</span>
              <%= link_to "Open workflow", issue.action_path, class: "text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="flex flex-col gap-2 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Review queue</h2>
        <p class="text-sm text-slate-500">Employee reviews by status, reviewer, rating, and calibration readiness.</p>
      </div>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= compact_number(@performance.calibratable_reviews.count) %> calibration-ready</span>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Cycle</th>
            <th class="px-5 py-3">Reviewer</th>
            <th class="px-5 py-3">Rating</th>
            <th class="px-5 py-3">Readiness</th>
            <th class="px-5 py-3">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @performance.reviews.each do |review| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to review.employee_name, employee_path(review.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= review.employee_title.presence || "Role pending" %> · <%= review.department_name || "Unassigned" %></p>
              </td>
              <td class="px-5 py-4 text-slate-600">
                <%= review.cycle_name %>
                <p class="mt-1 text-xs text-slate-500">Due <%= review.due_on.strftime("%b %-d, %Y") %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= review.reviewer_name %></td>
              <td class="px-5 py-4">
                <span class="rounded-md bg-slate-50 px-3 py-2 text-sm font-semibold text-slate-700"><%= review.rating || "Pending" %></span>
              </td>
              <td class="px-5 py-4">
                <%= status_pill(review.readiness_status) %>
                <p class="mt-1 max-w-52 text-xs text-slate-500"><%= review.readiness_reason %></p>
              </td>
              <td class="px-5 py-4">
                <% if review.calibratable? %>
                  <%= button_to "Calibrate", calibrate_performance_review_path(review.id), method: :post, params: { calibrated_by: "Musto Operations" }, class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <% else %>
                  <span class="text-xs font-semibold text-slate-400">No action</span>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @performance.reviews.empty? %>
            <tr>
              <td colspan="6" class="px-5 py-5 text-sm text-slate-600">No performance reviews exist yet. Launch a cycle to create review assignments.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="flex flex-col gap-2 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Goal tracker</h2>
        <p class="text-sm text-slate-500">Employee goals, progress, risk state, due dates, and completion actions.</p>
      </div>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= compact_number(@performance.open_goals.count) %> open goals</span>
    </div>
    <div class="grid divide-y divide-slate-100 lg:grid-cols-2 lg:divide-x lg:divide-y-0">
      <% @performance.goals.each do |goal| %>
        <article class="p-5">
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <p class="font-semibold text-slate-950"><%= goal.title %></p>
                <%= status_pill(goal.status) %>
              </div>
              <p class="mt-1 text-sm text-slate-500"><%= goal.employee_name %> · <%= goal.department_name || "Unassigned" %> · due <%= goal.due_on.strftime("%b %-d") %></p>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= goal.description.presence || goal.metric.presence || "No goal description provided." %></p>
            </div>
            <% if goal.completable? %>
              <%= button_to "Complete", complete_employee_goal_path(goal.id), method: :post, params: { reviewed_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
            <% else %>
              <%= status_pill("complete") %>
            <% end %>
          </div>
          <div class="mt-5 h-2 overflow-hidden rounded-full bg-slate-100">
            <div class="h-full rounded-full bg-violet-600" style="width: <%= goal.progress_percent %>%"></div>
          </div>
          <div class="mt-3 flex flex-wrap items-center justify-between gap-3">
            <p class="text-sm font-semibold text-slate-700"><%= goal.progress_percent %>% complete</p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">Owner: <%= goal.owner.humanize %></span>
              <% if goal.metric.present? %>
                <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600"><%= goal.metric %></span>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
      <% if @performance.goals.empty? %>
        <div class="p-5 text-sm text-slate-600">No employee goals exist yet.</div>
      <% end %>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Calibration packet ledger</h2>
      <p class="text-sm text-slate-500">Manager reviews included in the latest calibration packet and holdbacks still waiting on review work.</p>
    </div>
    <% if latest_batch.present? %>
      <div class="grid gap-4 border-b border-slate-100 bg-slate-50 px-5 py-4 lg:grid-cols-[1.2fr_0.8fr]">
        <div class="min-w-0">
          <div class="flex flex-wrap items-center gap-2">
            <%= status_pill(latest_batch.status) %>
            <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-200">Calibration packet</span>
          </div>
          <p class="mt-3 break-all font-mono text-sm font-semibold text-slate-950"><%= latest_batch.batch_id %></p>
          <p class="mt-2 text-sm text-slate-500">Generated <%= time_ago_in_words(latest_batch.generated_at) %> ago by <%= operator_name(latest_batch.requested_by) %></p>
        </div>
        <div class="grid grid-cols-4 gap-2 text-center">
          <div class="rounded-md bg-white px-3 py-3 shadow-sm ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Reviews</p>
            <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(latest_batch.review_count) %></p>
          </div>
          <div class="rounded-md bg-white px-3 py-3 shadow-sm ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">People</p>
            <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(latest_batch.employee_count) %></p>
          </div>
          <div class="rounded-md bg-white px-3 py-3 shadow-sm ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Avg.</p>
            <p class="mt-1 text-lg font-semibold text-slate-950"><%= latest_batch.average_rating %></p>
          </div>
          <div class="rounded-md bg-white px-3 py-3 shadow-sm ring-1 ring-inset ring-slate-200">
            <p class="text-xs text-slate-500">Held</p>
            <p class="mt-1 text-lg font-semibold text-slate-950"><%= compact_number(latest_batch.holdback_count) %></p>
          </div>
        </div>
      </div>
      <div class="grid divide-y divide-slate-100 xl:grid-cols-[1fr_0.86fr] xl:divide-x xl:divide-y-0">
        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase text-slate-400">Calibration lines</p>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-sm">
              <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
                <tr>
                  <th class="px-5 py-3">Employee</th>
                  <th class="px-5 py-3">Reviewer</th>
                  <th class="px-5 py-3">Rating</th>
                  <th class="px-5 py-3">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% @performance.calibration_lines.each do |line| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-5 py-4 font-semibold text-slate-950"><%= line.employee_name %><p class="mt-1 text-xs font-normal text-slate-500"><%= line.department_name || "Unassigned" %></p></td>
                    <td class="px-5 py-4 text-slate-600"><%= line.reviewer_name %></td>
                    <td class="px-5 py-4 text-slate-600"><%= line.rating || "Pending" %></td>
                    <td class="px-5 py-4"><%= status_pill(line.status) %></td>
                  </tr>
                <% end %>
                <% if @performance.calibration_lines.empty? %>
                  <tr>
                    <td colspan="4" class="px-5 py-5 text-sm text-slate-600">No manager reviews were included in this packet.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
          </div>
          <div class="divide-y divide-slate-100">
            <% @performance.calibration_holdbacks.each do |holdback| %>
              <div class="p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-950"><%= holdback.employee_name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= holdback.reason %></p>
                  </div>
                  <%= status_pill(holdback.status) %>
                </div>
              </div>
            <% end %>
            <% if @performance.calibration_holdbacks.empty? %>
              <div class="p-5">
                <p class="font-semibold text-slate-950">No holdbacks</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">All manager reviews were included in the latest packet.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="p-5">
        <p class="font-semibold text-slate-950">No generated calibration packet</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Manager-ready reviews and holdbacks will appear here after packet generation.</p>
      </div>
    <% end %>
  </section>
</section>
