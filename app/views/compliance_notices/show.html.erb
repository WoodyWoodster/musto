<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.2fr_0.8fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@notices.packet&.status || "pending") %>
          <span class="rounded-full bg-orange-50 px-3 py-1 text-xs font-semibold text-orange-800 ring-1 ring-inset ring-orange-200">Agency notices</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Response packet</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Compliance notices</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Triage payroll, tax, labor, and benefits notices, assign response ownership, retain agency evidence, and package audit-ready response details for finance and people operations.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Risk center", compliance_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Tax setup", tax_agency_registrations_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Documents", documents_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= button_to "Generate notice packet", generate_compliance_notice_packet_path, method: :post, params: { requested_by: "compliance_admin" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-orange-300">Latest notice packet</p>
        <% if @notices.packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @notices.packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-300">Generated <%= time_ago_in_words(@notices.packet.generated_at) %> ago by <%= @notices.packet.requested_by %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Open</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@notices.packet.open_count) %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@notices.packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Amount at risk</p>
            <p class="mt-2 text-2xl font-semibold"><%= money_cents(@notices.packet.amount_cents) %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Generate a response packet after notice ownership and due-date risk have been reviewed.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @notices.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">
          <% if metric.format == "money" %>
            <%= money_cents(metric.value) %>
          <% elsif metric.format == "text" %>
            <%= metric.value %>
          <% else %>
            <%= compact_number(metric.value) %>
          <% end %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 px-5 py-4">
        <div>
          <h2 class="text-base font-semibold text-slate-950">Notice response queue</h2>
          <p class="text-sm text-slate-500">Agency notices with due dates, response ownership, employee linkage, and action state.</p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= compact_number(@notices.actionable_notices.count) %> actionable</span>
      </div>
      <div class="divide-y divide-slate-100">
        <% @notices.notices.each do |notice| %>
          <article class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= notice.jurisdiction %> · <%= notice.notice_type.humanize %></p>
                <h3 class="mt-2 text-lg font-semibold tracking-tight text-slate-950"><%= notice.title %></h3>
                <p class="mt-1 text-sm leading-6 text-slate-600"><%= notice.summary.presence || "No notice summary recorded." %></p>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <%= status_pill(notice.severity) %>
                <%= status_pill(notice.status) %>
              </div>
            </div>

            <div class="mt-5 grid gap-3 md:grid-cols-4">
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Due</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= notice.due_on.strftime("%b %-d, %Y") %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Amount</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= money_cents(notice.amount_cents) %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Owner</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= notice.response_owner %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Reference</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= notice.reference_number.presence || "Missing" %></p>
              </div>
            </div>

            <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-slate-100 pt-4">
              <p class="text-sm text-slate-500">
                <%= notice.agency_name %>
                <% if notice.employee_name.present? %>
                  <span> · <%= notice.employee_name %></span>
                <% end %>
                <span> · via <%= notice.response_channel.humanize.downcase %></span>
              </p>
              <div class="flex flex-wrap gap-2">
                <% if notice.status == "received" %>
                  <%= button_to "Acknowledge", acknowledge_compliance_notice_path(notice.id), method: :post, params: { acknowledged_by: "compliance_admin" }, class: "rounded-md bg-cyan-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cyan-700" %>
                <% end %>
                <% if notice.actionable %>
                  <%= button_to "Resolve", resolve_compliance_notice_path(notice.id), method: :post, params: { resolved_by: "compliance_admin", resolution_summary: "Response submitted and supporting evidence retained." }, class: "rounded-md bg-slate-950 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
                <% else %>
                  <span class="rounded-md border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-600">Evidence retained</span>
                <% end %>
              </div>
            </div>
          </article>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Notice holdbacks</h2>
        <p class="text-sm text-slate-500">Items that should be cleared before a response packet is treated as audit-ready.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @notices.issues.any? %>
          <% @notices.issues.each do |issue| %>
            <div class="p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="min-w-0">
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= issue.jurisdiction %> · <%= issue.severity %></p>
                  <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.reason_code.humanize %></h3>
                </div>
                <%= status_pill(issue.status) %>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
              <p class="mt-3 text-xs font-semibold uppercase tracking-wide text-slate-400"><%= issue.response_owner %> · due <%= issue.due_on.strftime("%b %-d") %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5">
            <%= status_pill("ready") %>
            <p class="mt-3 text-sm leading-6 text-slate-600">All notices have ownership, references, and response evidence.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Agency notice matrix</h2>
      <p class="text-sm text-slate-500">A finance-friendly view of notices, deadlines, references, and current response posture.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Notice</th>
            <th class="px-5 py-3">Agency</th>
            <th class="px-5 py-3">Received</th>
            <th class="px-5 py-3">Due</th>
            <th class="px-5 py-3">Amount</th>
            <th class="px-5 py-3">Owner</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @notices.notices.each do |notice| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <p class="font-semibold text-slate-950"><%= notice.title %></p>
                <p class="mt-1 text-xs text-slate-500"><%= notice.reference_number.presence || "Reference missing" %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= notice.agency_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= notice.received_on.strftime("%b %-d, %Y") %></td>
              <td class="px-5 py-4 text-slate-600"><%= notice.due_on.strftime("%b %-d, %Y") %></td>
              <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(notice.amount_cents) %></td>
              <td class="px-5 py-4 text-slate-600"><%= notice.response_owner %></td>
              <td class="px-5 py-4"><%= status_pill(notice.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet notice lines</h2>
        <p class="text-sm text-slate-500">Notice data frozen into the latest generated response packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @notices.packet_lines.any? %>
          <% @notices.packet_lines.each do |line| %>
            <div class="grid gap-4 px-5 py-4 md:grid-cols-[1fr_auto] md:items-center">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="font-semibold text-slate-950"><%= line.title %></p>
                  <%= status_pill(line.status) %>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= line.agency_name %> · <%= line.jurisdiction %> · <%= line.reference_number.presence || "reference missing" %></p>
              </div>
              <p class="text-sm font-semibold text-slate-950"><%= money_cents(line.amount_cents) %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5">
            <p class="text-sm leading-6 text-slate-600">No packet lines yet. Generate a response packet after triaging the notice queue.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet holdbacks</h2>
        <p class="text-sm text-slate-500">Issues captured at packet generation time.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @notices.packet_holdbacks.any? %>
          <% @notices.packet_holdbacks.each do |holdback| %>
            <div class="p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= holdback.jurisdiction %> · <%= holdback.severity %></p>
                  <h3 class="mt-2 text-base font-semibold text-slate-950"><%= holdback.reason_code.humanize %></h3>
                </div>
                <%= status_pill(holdback.status) %>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5">
            <p class="text-sm leading-6 text-slate-600">Holdbacks will appear here after packet generation.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</section>
