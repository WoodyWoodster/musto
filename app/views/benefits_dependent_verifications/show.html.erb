<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.16fr_0.84fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-pink-50 px-3 py-1 text-xs font-semibold text-pink-700 ring-1 ring-inset ring-pink-200">Dependent verification</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-700 ring-1 ring-inset ring-cyan-200">Eligibility packet</span>
          <%= status_pill(@dependent_verifications.packet&.status || "pending") %>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Dependent verification center</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Request and review spouse, partner, and child verification documents before dependent records are included in a Vitable-ready eligibility packet for <%= @dependent_verifications.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Request missing verifications", request_dependent_verifications_path, method: :post, params: { requested_by: "Benefits Team" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Generate dependent packet", generate_dependent_verification_packet_path, method: :post, params: { requested_by: "Benefits Team" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Eligibility sync", benefits_eligibility_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Open enrollment", benefits_open_enrollment_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-pink-300">Latest dependent packet</p>
        <% if @dependent_verifications.packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @dependent_verifications.packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@dependent_verifications.packet.generated_at) %> ago by <%= operator_name(@dependent_verifications.packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Ready</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@dependent_verifications.packet.ready_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@dependent_verifications.packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Dependents</p>
            <p class="mt-2 text-2xl font-semibold"><%= compact_number(@dependent_verifications.packet.dependent_count) %></p>
            <p class="mt-2 text-xs text-slate-400">records evaluated for packet inclusion</p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate a packet after dependent documents have been requested and reviewed.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @dependent_verifications.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold text-slate-950">
          <%= metric.format == "number" ? compact_number(metric.value) : metric.value %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.08fr_0.92fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Dependent roster</h2>
        <p class="text-sm text-slate-500">Eligibility, document, and remote-member readiness for every dependent.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Dependent</th>
              <th class="px-5 py-3">Employee</th>
              <th class="px-5 py-3">Verification</th>
              <th class="px-5 py-3">Document</th>
              <th class="px-5 py-3">Remote</th>
              <th class="px-5 py-3">Readiness</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @dependent_verifications.dependents.each do |dependent| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4">
                  <p class="font-semibold text-slate-950"><%= dependent.dependent_name %></p>
                  <p class="mt-1 text-xs text-slate-500"><%= dependent.relationship.humanize %> · <%= dependent.date_of_birth&.strftime("%b %-d, %Y") || "DOB missing" %></p>
                </td>
                <td class="px-5 py-4"><%= link_to dependent.employee_name, employee_path(dependent.employee_id), class: "font-medium text-slate-700 hover:text-cyan-700" %></td>
                <td class="px-5 py-4">
                  <%= status_pill(dependent.verification_status) %>
                  <p class="mt-1 text-xs text-slate-500"><%= dependent.verification_type.humanize %></p>
                </td>
                <td class="px-5 py-4"><%= status_pill(dependent.document_status) %></td>
                <td class="px-5 py-4">
                  <%= status_pill(dependent.remote_dependent_id.present? ? "synced" : "remote_pending") %>
                  <p class="mt-1 max-w-36 truncate text-xs text-slate-500"><%= dependent.remote_dependent_id.presence || "Create on sync" %></p>
                </td>
                <td class="px-5 py-4">
                  <%= status_pill(dependent.readiness_status) %>
                  <p class="mt-1 max-w-64 text-xs text-slate-500"><%= dependent.readiness_reason %></p>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Readiness issues</h2>
        <p class="text-sm text-slate-500">Holdbacks that keep dependents out of the next eligibility packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @dependent_verifications.issues.each do |issue| %>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= issue.reason_code.humanize %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.dependent_name %></h3>
                <p class="mt-1 text-sm text-slate-500"><%= issue.employee_name %></p>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
          </div>
        <% end %>
        <% if @dependent_verifications.issues.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">Every dependent is ready for packet inclusion.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Verification review queue</h2>
      <p class="text-sm text-slate-500">Complete documents can be approved into eligibility, while mismatches stay visible for follow-up.</p>
    </div>
    <div class="divide-y divide-slate-100">
      <% @dependent_verifications.verifications.each do |verification| %>
        <div class="p-5">
          <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
            <div class="min-w-0">
              <div class="flex flex-wrap items-center gap-2">
                <%= status_pill(verification.status) %>
                <%= status_pill(verification.document_status) %>
              </div>
              <h3 class="mt-3 text-base font-semibold text-slate-950"><%= verification.dependent_name %></h3>
              <p class="mt-1 text-sm text-slate-500"><%= verification.employee_name %> · <%= verification.verification_type.humanize %> · due <%= verification.due_on.strftime("%b %-d") %></p>
              <p class="mt-2 text-sm text-slate-600"><%= verification.document_title.presence || "No document attached" %></p>
              <% if verification.note.present? %>
                <p class="mt-2 text-sm text-rose-700"><%= verification.note %></p>
              <% end %>
            </div>
            <div class="flex shrink-0 flex-wrap gap-2">
              <% if verification.reviewable? %>
                <%= button_to "Approve", approve_dependent_verification_path(verification.id), method: :post, params: { reviewed_by: "Benefits Team" }, class: "rounded-md bg-emerald-600 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <%= button_to "Reject", reject_dependent_verification_path(verification.id), method: :post, params: { reviewed_by: "Benefits Team", issue_code: "document_mismatch", note: "Document does not match dependent profile." }, class: "rounded-md border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
              <% elsif verification.reviewed_at.present? %>
                <p class="rounded-md bg-slate-100 px-3 py-2 text-xs font-semibold text-slate-600">Reviewed <%= time_ago_in_words(verification.reviewed_at) %> ago</p>
              <% else %>
                <p class="rounded-md bg-amber-50 px-3 py-2 text-xs font-semibold text-amber-800 ring-1 ring-inset ring-amber-200">Waiting on document</p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
      <% if @dependent_verifications.verifications.empty? %>
        <p class="px-5 py-5 text-sm text-slate-500">No verification requests have been prepared yet.</p>
      <% end %>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet dependents</h2>
        <p class="text-sm text-slate-500">Verified dependent lines from the latest generated packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @dependent_verifications.packet_lines.each do |line| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= line.dependent_name %></p>
              <p class="mt-1 text-sm text-slate-500"><%= line.employee_name %> · <%= line.relationship.humanize %> · <%= line.verification_type.humanize %></p>
            </div>
            <%= status_pill(line.status) %>
          </div>
        <% end %>
        <% if @dependent_verifications.packet_lines.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">Generate a packet after approving dependent verifications.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet holdbacks</h2>
        <p class="text-sm text-slate-500">Persisted blockers from the latest dependent verification packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @dependent_verifications.packet_holdbacks.each do |issue| %>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= issue.dependent_name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= issue.employee_name %></p>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
          </div>
        <% end %>
        <% if @dependent_verifications.packet_holdbacks.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No packet holdbacks have been captured yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</section>
