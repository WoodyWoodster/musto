<% last_verification = @connection.metadata.fetch("last_verification", {}) %>

<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.2fr_0.8fr]">
      <div class="p-6 lg:p-8">
        <%= link_to "Back to integrations", integrations_path, class: "text-sm font-semibold text-amber-700 hover:text-amber-900" %>
        <div class="mt-5 flex flex-wrap items-center gap-2">
          <%= status_pill(@connection.status) %>
          <%= status_pill(@connection.credentials_present ? "connected" : "needs_credentials") %>
          <span class="inline-flex items-center rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700 ring-1 ring-inset ring-slate-200"><%= @connection.environment.humanize %></span>
        </div>
        <h1 class="mt-5 break-words text-4xl font-semibold text-slate-950"><%= @connection.organization_name %> Vitable connection</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Manage credential readiness, event routing, resource coverage, and sync history for this benefits partner connection.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <%= button_to "Verify credentials", verify_credentials_integration_connection_path(@connection.id), method: :post, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Refresh API snapshot", refresh_api_snapshot_integration_connection_path(@connection.id), method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
          <%= link_to "API docs", @connection.docs_url, target: "_blank", rel: "noopener", class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
          <%= link_to "Partner guide", @connection.ruby_docs_url, target: "_blank", rel: "noopener", class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
          <%= link_to "Webhooks", @connection.webhooks_docs_url, target: "_blank", rel: "noopener", class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Connection identity</p>
        <div class="mt-6 space-y-5">
          <div>
            <p class="text-sm text-slate-600">Organization external ID</p>
            <p class="mt-1 break-all font-mono text-sm font-semibold"><%= @connection.organization_external_id %></p>
          </div>
          <div>
            <p class="text-sm text-slate-600">API target</p>
            <p class="mt-1 break-all font-mono text-sm font-semibold"><%= @connection.api_base_url.presence || @connection.sdk_environment || @connection.environment %></p>
          </div>
          <div class="h-px bg-slate-200"></div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-sm text-slate-600">Provider</p>
              <p class="mt-1 font-semibold"><%= @connection.provider %></p>
            </div>
            <div>
              <p class="text-sm text-slate-600">Last sync</p>
              <p class="mt-1 font-semibold"><%= @connection.last_synced_at&.strftime("%b %-d, %I:%M %p") || "Not yet" %></p>
            </div>
          </div>
          <div class="rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Last verification</p>
            <p class="mt-2 text-sm font-semibold text-slate-950"><%= last_verification.fetch("status", "not checked").to_s.humanize %></p>
            <p class="mt-1 break-words text-sm text-slate-600"><%= last_verification.fetch("message", "No verification attempt has been recorded.") %></p>
          </div>
        </div>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <% @connection.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <%= status_pill(metric.status) %>
        </div>
        <p class="mt-4 break-words text-2xl font-semibold text-slate-950"><%= metric.value %></p>
      </article>
    <% end %>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
        <div>
          <h2 class="text-base font-semibold text-slate-950">Remote API snapshot</h2>
          <p class="text-sm text-slate-500">Latest read mirror from Vitable employers, rosters, groups, plans, eligibility policies, webhook events, and employee enrollments.</p>
        </div>
        <%= status_pill(@connection.api_snapshot.present? ? "ready" : "pending") %>
      </div>
    </div>
    <% if @connection.api_snapshot.present? %>
      <div class="grid gap-0 divide-y divide-slate-100 md:grid-cols-4 md:divide-x md:divide-y-0 xl:grid-cols-8">
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Refreshed</p>
          <p class="mt-2 text-sm font-semibold text-slate-950"><%= time_ago_in_words(@connection.api_snapshot.refreshed_at) %> ago</p>
        </div>
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Employers</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= compact_number(@connection.api_snapshot.remote_employer_count) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.mapped_employer_count) %> mapped</p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.retrieved_remote_employer_count) %> detail mirrors</p>
          <% if @connection.api_snapshot.unmatched_remote_employer_count.positive? || @connection.api_snapshot.conflicting_remote_employer_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.unmatched_remote_employer_count) %> unmatched - <%= compact_number(@connection.api_snapshot.conflicting_remote_employer_count) %> conflicts</p>
          <% end %>
          <% if @connection.api_snapshot.errored_remote_employer_detail_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.errored_remote_employer_detail_count) %> detail errors</p>
          <% end %>
        </div>
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Groups</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= compact_number(@connection.api_snapshot.remote_group_count) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.mapped_group_count) %> mapped</p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.retrieved_remote_group_count) %> detail mirrors</p>
          <% if @connection.api_snapshot.unmatched_remote_group_count.positive? || @connection.api_snapshot.conflicting_remote_group_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.unmatched_remote_group_count) %> unmatched - <%= compact_number(@connection.api_snapshot.conflicting_remote_group_count) %> conflicts</p>
          <% end %>
          <% if @connection.api_snapshot.errored_remote_group_detail_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.errored_remote_group_detail_count) %> detail errors</p>
          <% end %>
        </div>
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Plans</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= compact_number(@connection.api_snapshot.remote_plan_count) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.mapped_plan_count) %> mapped</p>
          <% if @connection.api_snapshot.unmatched_remote_plan_count.positive? || @connection.api_snapshot.unmatched_local_plan_count.positive? || @connection.api_snapshot.ambiguous_remote_plan_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.unmatched_remote_plan_count) %> remote - <%= compact_number(@connection.api_snapshot.unmatched_local_plan_count) %> local - <%= compact_number(@connection.api_snapshot.ambiguous_remote_plan_count) %> ambiguous</p>
          <% end %>
        </div>
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Eligibility</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= compact_number(@connection.api_snapshot.remote_eligibility_policy_count) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.matched_eligibility_policy_count) %> matched</p>
          <% if @connection.api_snapshot.errored_eligibility_policy_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.errored_eligibility_policy_count) %> read errors</p>
          <% end %>
        </div>
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Webhook events</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= compact_number(@connection.api_snapshot.remote_webhook_event_count) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.imported_webhook_event_count) %> imported - <%= compact_number(@connection.api_snapshot.existing_webhook_event_count) %> existing</p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.dependent_webhook_event_count) %> dependents - <%= compact_number(@connection.api_snapshot.payroll_deduction_webhook_event_count) %> deductions - <%= compact_number(@connection.api_snapshot.plan_year_webhook_event_count) %> plan years</p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.recovered_webhook_event_count) %> recovered</p>
          <% if @connection.api_snapshot.failed_webhook_recovery_count.positive? || @connection.api_snapshot.skipped_webhook_recovery_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.failed_webhook_recovery_count) %> failed - <%= compact_number(@connection.api_snapshot.skipped_webhook_recovery_count) %> skipped</p>
          <% end %>
        </div>
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Employees</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= compact_number(@connection.api_snapshot.remote_employee_count) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.mapped_employee_count) %> mapped</p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.retrieved_remote_employee_count) %> detail mirrors</p>
          <% if @connection.api_snapshot.unmatched_remote_employee_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.unmatched_remote_employee_count) %> unmatched</p>
          <% end %>
          <% if @connection.api_snapshot.errored_remote_employee_detail_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.errored_remote_employee_detail_count) %> detail errors</p>
          <% end %>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.remote_employee_deduction_changed_count) %> deduction changes</p>
          <% if @connection.api_snapshot.inactive_employee_enrollment_count.positive? || @connection.api_snapshot.inactive_employee_payroll_deduction_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.inactive_employee_enrollment_count) %> inactive enrollments - <%= compact_number(@connection.api_snapshot.inactive_employee_payroll_deduction_count) %> deductions</p>
          <% end %>
        </div>
        <div class="p-5">
          <p class="text-xs font-semibold uppercase text-slate-400">Enrollments</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= compact_number(@connection.api_snapshot.remote_employee_enrollment_count) %></p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.reconciled_enrollment_count) %> reconciled - <%= compact_number(@connection.api_snapshot.updated_enrollment_count) %> updated</p>
          <p class="mt-1 text-xs text-slate-500"><%= compact_number(@connection.api_snapshot.enrollment_deduction_changed_count) %> deduction changes</p>
          <% if @connection.api_snapshot.enrollment_missing_plan_count.positive? %>
            <p class="mt-1 text-xs font-semibold text-amber-700"><%= compact_number(@connection.api_snapshot.enrollment_missing_plan_count) %> missing plan mappings</p>
          <% end %>
        </div>
      </div>
    <% else %>
      <p class="px-5 py-5 text-sm text-slate-500">Refresh the API snapshot to mirror Vitable read endpoints into this workspace.</p>
    <% end %>
  </section>

  <section class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1fr_0.85fr]">
      <div class="p-5 lg:p-6">
        <div class="flex flex-col gap-2 border-b border-slate-100 pb-5 md:flex-row md:items-start md:justify-between">
          <div>
            <h2 class="text-base font-semibold text-slate-950">Test event composer</h2>
            <p class="mt-1 text-sm text-slate-500">Create a test event and run it through the webhook intake and reconciliation flow.</p>
          </div>
          <%= status_pill(@connection.credentials_missing? ? "needs_credentials" : "ready") %>
        </div>

        <%= form_with url: simulate_webhook_integration_connection_path(@connection.id), method: :post, class: "mt-5 grid gap-4 lg:grid-cols-2", data: { controller: "vitable-webhook-simulator" } do %>
          <div>
            <%= label_tag :event_name, "Event type", class: "text-xs font-semibold uppercase text-slate-500" %>
            <%= select_tag :event_name,
              options_for_select(
                @connection.simulator.event_options.map do |option|
                  [
                    option.label,
                    option.event_name,
                    {
                      data: {
                        resource_type: option.resource_type,
                        resource_id: option.sample_resource_id
                      }
                    }
                  ]
                end,
                @connection.simulator.default_event_name
              ),
              class: "mt-2 w-full rounded-md border border-slate-200 bg-white px-3 py-3 text-sm font-medium text-slate-950 shadow-sm focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-100",
              data: { vitable_webhook_simulator_target: "event", action: "change->vitable-webhook-simulator#sync" } %>
          </div>

          <div>
            <%= label_tag :resource_type, "Resource type", class: "text-xs font-semibold uppercase text-slate-500" %>
            <%= select_tag :resource_type,
              options_for_select(@connection.simulator.resource_options.map { |resource_type| [ resource_type.humanize, resource_type ] }, @connection.simulator.default_resource_type),
              class: "mt-2 w-full rounded-md border border-slate-200 bg-white px-3 py-3 text-sm font-medium text-slate-950 shadow-sm focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-100",
              data: { vitable_webhook_simulator_target: "resourceType" } %>
          </div>

          <div>
            <%= label_tag :resource_id, "Resource ID", class: "text-xs font-semibold uppercase text-slate-500" %>
            <%= text_field_tag :resource_id,
              @connection.simulator.default_resource_id,
              class: "mt-2 w-full rounded-md border border-slate-200 bg-white px-3 py-3 font-mono text-sm text-slate-950 shadow-sm focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-100",
              data: { vitable_webhook_simulator_target: "resourceId" },
              autocomplete: "off" %>
          </div>

          <div>
            <%= label_tag :event_id, "Event ID override", class: "text-xs font-semibold uppercase text-slate-500" %>
            <%= text_field_tag :event_id,
              nil,
              placeholder: "Auto-generated",
              class: "mt-2 w-full rounded-md border border-slate-200 bg-white px-3 py-3 font-mono text-sm text-slate-950 shadow-sm placeholder:text-slate-400 focus:border-amber-400 focus:outline-none focus:ring-2 focus:ring-amber-100",
              autocomplete: "off" %>
          </div>

          <div class="lg:col-span-2">
            <%= submit_tag "Process test event", class: "w-full rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800 md:w-auto" %>
          </div>
        <% end %>
      </div>

      <aside class="border-t border-slate-200 bg-slate-50 p-5 lg:p-6 xl:border-l xl:border-t-0">
        <h3 class="text-sm font-semibold text-slate-950">Payload contract</h3>
        <dl class="mt-4 grid gap-3 text-sm">
          <div class="rounded-md bg-white p-3 shadow-sm ring-1 ring-slate-200">
            <dt class="text-xs font-semibold uppercase text-slate-400">Organization</dt>
            <dd class="mt-1 break-all font-mono text-xs text-slate-700"><%= @connection.organization_external_id %></dd>
          </div>
          <div class="rounded-md bg-white p-3 shadow-sm ring-1 ring-slate-200">
            <dt class="text-xs font-semibold uppercase text-slate-400">Result</dt>
            <dd class="mt-1 text-sm text-slate-700"><%= @connection.credentials_missing? ? "Queued until credentials exist" : "Fetches retrievable resources; payload-only resources reconcile from event data." %></dd>
          </div>
          <div class="rounded-md bg-white p-3 shadow-sm ring-1 ring-slate-200">
            <dt class="text-xs font-semibold uppercase text-slate-400">Idempotency</dt>
            <dd class="mt-1 text-sm text-slate-700">Duplicate event IDs reuse the stored webhook event.</dd>
          </div>
        </dl>
      </aside>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Readiness checks</h2>
        <p class="text-sm text-slate-500">Operational state before live Vitable resource fetches run.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @connection.health_checks.each do |check| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= check.label %></p>
              <p class="mt-1 break-words text-sm text-slate-500"><%= check.detail %></p>
            </div>
            <%= status_pill(check.status) %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">API coverage</h2>
        <p class="text-sm text-slate-500">Documented Vitable API and webhook surfaces exercised by request logs, sync runs, snapshots, and resource events.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Resource</th>
              <th class="px-5 py-3">Method</th>
              <th class="px-5 py-3">Fetch path</th>
              <th class="px-5 py-3">Activity</th>
              <th class="px-5 py-3">Last activity</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @connection.endpoint_coverage.each do |coverage| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4 font-medium text-slate-950"><%= coverage.resource_type.humanize %></td>
                <td class="px-5 py-4 text-xs font-semibold text-slate-500"><%= coverage.method %></td>
                <td class="px-5 py-4 font-mono text-xs text-slate-600"><%= coverage.fetch_path %></td>
                <td class="px-5 py-4 text-slate-600"><%= coverage.activity_count %></td>
                <td class="px-5 py-4 text-slate-600"><%= coverage.last_seen_at ? time_ago_in_words(coverage.last_seen_at) + " ago" : "n/a" %></td>
                <td class="px-5 py-4"><%= status_pill(coverage.status) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Connection timeline</h2>
        <p class="text-sm text-slate-500">Recent webhook, sync, and API activity for this connection.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @connection.timeline.each do |item| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase text-slate-400"><%= item.type %></p>
              <p class="mt-1 break-all font-medium text-slate-950"><%= item.title %></p>
              <p class="mt-1 break-all text-sm text-slate-500"><%= item.subtitle %></p>
              <p class="mt-1 text-xs text-slate-400"><%= time_ago_in_words(item.timestamp) %> ago</p>
            </div>
            <%= status_pill(item.status) %>
          </div>
        <% end %>
        <% if @connection.timeline.empty? %>
          <p class="px-5 py-4 text-sm text-slate-500">No connection activity has been recorded yet.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Webhook queue</h2>
        <p class="text-sm text-slate-500">Recent events routed to this Vitable connection.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Event</th>
              <th class="px-5 py-3">Resource</th>
              <th class="px-5 py-3">Received</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @connection.webhook_events.each do |event| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4">
                  <%= link_to event.event_name, webhook_event_path(event.id), class: "font-medium text-slate-950 hover:text-amber-700" %>
                  <p class="break-all text-xs text-slate-500"><%= event.event_id %></p>
                </td>
                <td class="px-5 py-4 text-slate-600"><span class="break-all"><%= event.resource_type %> · <%= event.resource_id %></span></td>
                <td class="px-5 py-4 text-slate-600"><%= time_ago_in_words(event.created_at) %> ago</td>
                <td class="px-5 py-4"><%= status_pill(event.status) %></td>
              </tr>
            <% end %>
            <% if @connection.webhook_events.empty? %>
              <tr>
                <td colspan="4" class="px-5 py-5 text-sm text-slate-500">No webhook events have been routed to this connection.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-2">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Sync runs</h2>
        <p class="text-sm text-slate-500">Fetch attempts created by webhook processing and manual operations.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @connection.sync_runs.each do |sync| %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="break-all font-semibold text-slate-950"><%= sync.operation.humanize %> <%= sync.resource_type %></p>
                <p class="mt-1 text-sm text-slate-500"><%= sync.started_at&.strftime("%b %-d, %I:%M %p") || "n/a" %></p>
              </div>
              <%= status_pill(sync.status) %>
            </div>
            <% if sync.error_message.present? %>
              <p class="mt-2 break-words rounded-md bg-rose-50 px-3 py-2 text-xs text-rose-700"><%= sync.error_message %></p>
            <% end %>
          </div>
        <% end %>
        <% if @connection.sync_runs.empty? %>
          <p class="px-5 py-4 text-sm text-slate-500">No sync runs yet.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Connection activity</h2>
        <p class="text-sm text-slate-500">Requests made through the Vitable client gateway.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Operation</th>
              <th class="px-5 py-3">Path</th>
              <th class="px-5 py-3">Status</th>
              <th class="px-5 py-3">Error</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @connection.request_logs.each do |log| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4 font-medium text-slate-950"><%= log.operation %></td>
                <td class="px-5 py-4 font-mono text-xs text-slate-600"><span class="break-all"><%= log.method %> <%= log.path %></span></td>
                <td class="px-5 py-4 text-slate-600"><%= log.status_code || "n/a" %></td>
                <td class="px-5 py-4 text-slate-600"><%= log.error_class.presence || "none" %></td>
              </tr>
            <% end %>
            <% if @connection.request_logs.empty? %>
              <tr>
                <td colspan="4" class="px-5 py-5 text-sm text-slate-500">No connection activity yet.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>
</section>
