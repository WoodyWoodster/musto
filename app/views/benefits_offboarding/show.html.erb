<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.14fr_0.86fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-rose-50 px-3 py-1 text-xs font-semibold text-rose-700 ring-1 ring-inset ring-rose-200">Coverage offboarding</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-700 ring-1 ring-inset ring-cyan-200">Vitable termination packet</span>
          <%= status_pill(@offboarding.packet&.status || "pending") %>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Benefits offboarding</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Convert approved termination lifecycle events into coverage termination lines, COBRA/compliance holdbacks, and a Vitable-ready packet for <%= @offboarding.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate termination packet", generate_benefits_offboarding_packet_path, method: :post, params: { requested_by: "Benefits Team" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= link_to "Lifecycle events", lifecycle_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Eligibility sync", benefits_eligibility_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Billing", benefits_billing_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-rose-300">Latest termination packet</p>
        <% if @offboarding.packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @offboarding.packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@offboarding.packet.generated_at) %> ago by <%= operator_name(@offboarding.packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Members</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@offboarding.packet.member_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@offboarding.packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Events</p>
            <p class="mt-2 text-2xl font-semibold"><%= compact_number(@offboarding.packet.event_count) %></p>
            <p class="mt-2 text-xs text-slate-400"><%= compact_number(@offboarding.packet.employee_count) %> employees included</p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate after termination events are approved and remote member IDs are available.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @offboarding.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold text-slate-950">
          <%= metric.format == "number" ? compact_number(metric.value) : metric.value %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.08fr_0.92fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Termination queue</h2>
        <p class="text-sm text-slate-500">Lifecycle events that affect active benefit coverage and need termination packaging.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @offboarding.events.each do |event| %>
          <article class="p-5">
            <div class="flex flex-col gap-4 xl:flex-row xl:items-start xl:justify-between">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <%= status_pill(event.status) %>
                  <%= status_pill(event.readiness_status) %>
                  <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= event.effective_on.strftime("%b %-d, %Y") %></span>
                </div>
                <h3 class="mt-3 text-base font-semibold text-slate-950"><%= event.employee_name %></h3>
                <p class="mt-1 text-sm leading-6 text-slate-600"><%= event.summary %></p>
                <p class="mt-2 text-xs text-slate-500"><%= event.enrollment_count %> enrollments · <%= event.covered_dependent_count %> covered dependents · <%= event.compliance_impact.humanize %></p>
              </div>
              <div class="w-full shrink-0 rounded-md bg-slate-50 p-4 xl:w-72">
                <p class="text-xs font-semibold uppercase text-slate-400">Readiness</p>
                <p class="mt-2 text-sm leading-6 text-slate-600"><%= event.readiness_reason %></p>
                <p class="mt-3 break-all font-mono text-xs text-slate-500"><%= event.remote_employee_id.presence || "remote employee pending" %></p>
              </div>
            </div>
          </article>
        <% end %>
        <% if @offboarding.events.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No termination events currently impact benefits coverage.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Offboarding blockers</h2>
        <p class="text-sm text-slate-500">Remote ID, approval, and coverage issues that block packet inclusion.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @offboarding.issues.each do |issue| %>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= issue.reason_code.humanize %> · <%= issue.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.employee_name %></h3>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
          </div>
        <% end %>
        <% if @offboarding.issues.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No offboarding blockers detected.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Coverage termination lines</h2>
      <p class="text-sm text-slate-500">Employee and dependent coverage rows that will be sent after approval, remote mapping, and COBRA review.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Member</th>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Plan</th>
            <th class="px-5 py-3">Coverage ends</th>
            <th class="px-5 py-3">Remote</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @offboarding.coverage_lines.each do |line| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <p class="font-semibold text-slate-950"><%= line.member_name %></p>
                <p class="mt-1 text-xs text-slate-500"><%= line.member_type.humanize %> · <%= line.relationship.humanize %></p>
              </td>
              <td class="px-5 py-4"><%= link_to line.employee_name, employee_path(line.employee_id), class: "font-medium text-slate-700 hover:text-cyan-700" %></td>
              <td class="px-5 py-4">
                <p class="font-medium text-slate-700"><%= line.plan_name %></p>
                <p class="mt-1 text-xs text-slate-500"><%= line.plan_category.humanize %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= line.coverage_end_on.strftime("%b %-d, %Y") %></td>
              <td class="px-5 py-4">
                <p class="max-w-40 truncate font-mono text-xs text-slate-600"><%= line.remote_member_id.presence || "member pending" %></p>
                <p class="mt-1 max-w-40 truncate font-mono text-xs text-slate-400"><%= line.remote_enrollment_id.presence || "enrollment pending" %></p>
              </td>
              <td class="px-5 py-4">
                <%= status_pill(line.status) %>
                <p class="mt-1 max-w-56 text-xs text-slate-500"><%= line.reason %></p>
              </td>
            </tr>
          <% end %>
          <% if @offboarding.coverage_lines.empty? %>
            <tr>
              <td colspan="6" class="px-5 py-5 text-sm text-slate-500">No active coverage lines are attached to benefits-impacting terminations.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet termination lines</h2>
        <p class="text-sm text-slate-500">Ready lines persisted from the latest generated packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @offboarding.packet_lines.each do |line| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= line.member_name %></p>
              <p class="mt-1 text-sm text-slate-500"><%= line.employee_name %> · <%= line.plan_name %> · ends <%= line.coverage_end_on.strftime("%b %-d") %></p>
            </div>
            <%= status_pill(line.status) %>
          </div>
        <% end %>
        <% if @offboarding.packet_lines.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">Generate a packet after ready offboarding lines are available.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet holdbacks</h2>
        <p class="text-sm text-slate-500">Persisted blockers captured when the latest packet was generated.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @offboarding.packet_holdbacks.each do |issue| %>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= issue.employee_name %></p>
                <p class="mt-1 text-xs font-semibold uppercase text-slate-400"><%= issue.reason_code.humanize %></p>
              </div>
              <%= status_pill(issue.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
          </div>
        <% end %>
        <% if @offboarding.packet_holdbacks.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No packet holdbacks have been captured yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</section>
