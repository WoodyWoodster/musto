<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.3fr_0.7fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@reports.generated? ? "ready" : "pending") %>
          <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold text-amber-800 ring-1 ring-inset ring-amber-200">Finance reports</span>
        </div>
        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Reports command center</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Payroll register, benefits cost, headcount spend, compliance risk, and export snapshot controls for <%= @reports.employer&.name || "your employer portfolio" %>.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Payroll", payroll_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Benefits", benefits_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= button_to "Generate snapshot", generate_reports_snapshot_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-300">Latest snapshot</p>
        <% if @reports.latest_snapshot.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @reports.latest_snapshot.snapshot_id %></p>
          <p class="mt-3 text-sm text-slate-300">Generated <%= time_ago_in_words(@reports.latest_snapshot.generated_at) %> ago by <%= @reports.latest_snapshot.requested_by %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Metrics</p>
              <p class="mt-2 text-2xl font-semibold"><%= @reports.latest_snapshot.metric_count %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Exports</p>
              <p class="mt-2 text-2xl font-semibold"><%= @reports.latest_snapshot.export_count %></p>
            </div>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">No package</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Generate a snapshot to persist the current reporting packet.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @reports.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950"><%= metric.format == "money" ? money_cents(metric.value) : compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Report library</h2>
      <p class="text-sm text-slate-500">Operational reports with direct drill-through to their source workflows.</p>
    </div>
    <div class="grid divide-y divide-slate-100 lg:grid-cols-4 lg:divide-x lg:divide-y-0">
      <% @reports.report_cards.each do |card| %>
        <%= link_to card.path, class: "p-5 hover:bg-slate-50" do %>
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= card.owner %></p>
              <h3 class="mt-2 text-base font-semibold text-slate-950"><%= card.title %></h3>
            </div>
            <%= status_pill(card.status) %>
          </div>
          <p class="mt-3 text-sm leading-6 text-slate-600"><%= card.description %></p>
          <div class="mt-5 flex items-center justify-between gap-3">
            <span class="text-sm font-semibold text-slate-950"><%= card.value %></span>
            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600"><%= card.cadence %></span>
          </div>
        <% end %>
      <% end %>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Department cost ledger</h2>
        <p class="text-sm text-slate-500">Payroll, benefits, deductions, and open risk by org unit.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-5 py-3">Department</th>
              <th class="px-5 py-3">People</th>
              <th class="px-5 py-3">Payroll</th>
              <th class="px-5 py-3">Benefits</th>
              <th class="px-5 py-3">Deductions</th>
              <th class="px-5 py-3">Risk</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @reports.department_costs.each do |department| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4 font-semibold text-slate-950"><%= department.department_name %></td>
                <td class="px-5 py-4 text-slate-600"><%= department.employee_count %></td>
                <td class="px-5 py-4 text-slate-600"><%= money_cents(department.payroll_cents) %></td>
                <td class="px-5 py-4 text-slate-600"><%= money_cents(department.benefit_cost_cents) %></td>
                <td class="px-5 py-4 text-slate-600"><%= money_cents(department.deduction_cents) %></td>
                <td class="px-5 py-4"><%= status_pill(department.risk_count.positive? ? "needs_review" : "ready") %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Benefits spend</h2>
        <p class="text-sm text-slate-500">Accepted enrollment cost by Vitable-backed plan.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @reports.benefit_spend.each do |plan| %>
          <div class="px-5 py-4">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div>
                <p class="font-semibold text-slate-950"><%= plan.plan_name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= plan.category.humanize %> · <%= plan.carrier %></p>
              </div>
              <%= status_pill(plan.status) %>
            </div>
            <div class="mt-4 grid grid-cols-3 gap-2 text-center">
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Accepted</p>
                <p class="mt-1 text-lg font-semibold text-slate-950"><%= plan.accepted_count %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Pending</p>
                <p class="mt-1 text-lg font-semibold text-slate-950"><%= plan.pending_count %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-2 py-3">
                <p class="text-xs text-slate-500">Monthly</p>
                <p class="mt-1 text-lg font-semibold text-slate-950"><%= money_cents(plan.monthly_cost_cents) %></p>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Risk register</h2>
      <p class="text-sm text-slate-500">Items finance and people teams should review before exports are shared.</p>
    </div>
    <div class="grid divide-y divide-slate-100 md:grid-cols-3 md:divide-x md:divide-y-0">
      <% @reports.risk_items.each do |item| %>
        <div class="p-5">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="font-semibold text-slate-950"><%= item.label %></p>
              <p class="mt-1 text-sm text-slate-500"><%= item.detail %></p>
            </div>
            <%= status_pill(item.status) %>
          </div>
          <p class="mt-5 text-3xl font-semibold tracking-tight text-slate-950"><%= compact_number(item.value) %></p>
          <p class="mt-1 text-xs font-semibold uppercase tracking-wide text-slate-400"><%= item.severity %> severity</p>
        </div>
      <% end %>
    </div>
  </section>
</section>
