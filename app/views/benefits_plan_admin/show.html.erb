<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.16fr_0.84fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Benefits catalog</span>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Vitable-ready packet</span>
          <%= status_pill(@plan_admin.packet&.status || "pending") %>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Benefit plan administration</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Model employer and employee contribution splits, verify plan readiness, publish approved catalog entries, and generate the local packet that would back a Vitable plan sync.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate catalog packet", generate_benefit_plan_catalog_packet_path, method: :post, params: { requested_by: "benefits_admin" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= link_to "Open enrollment", benefits_open_enrollment_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Eligibility", benefits_eligibility_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Billing", benefits_billing_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-300">Latest plan packet</p>
        <% if @plan_admin.packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @plan_admin.packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-300">Generated <%= time_ago_in_words(@plan_admin.packet.generated_at) %> ago by <%= @plan_admin.packet.requested_by %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Ready plans</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@plan_admin.packet.ready_count) %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@plan_admin.packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Monthly premium</p>
            <p class="mt-2 text-2xl font-semibold"><%= money_cents(@plan_admin.packet.monthly_premium_cents) %></p>
            <p class="mt-2 text-xs text-slate-400"><%= money_cents(@plan_admin.packet.employer_contribution_cents) %> employer contribution modeled</p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Generate a catalog packet to lock the current plan payload, holdbacks, and contribution totals for review.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @plan_admin.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold tracking-tight text-slate-950">
          <% if metric.format == "money" %>
            <%= money_cents(metric.value) %>
          <% elsif metric.format == "number" %>
            <%= compact_number(metric.value) %>
          <% else %>
            <%= metric.value %>
          <% end %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Plan design catalog</h2>
      <p class="text-sm text-slate-500">Contribution model, eligibility rules, enrollment adoption, and publish readiness by plan.</p>
    </div>
    <div class="divide-y divide-slate-100">
      <% @plan_admin.plans.each do |plan| %>
        <% employee_share = plan.monthly_premium_cents.positive? ? ((plan.employee_contribution_cents.to_f / plan.monthly_premium_cents) * 100).round : 0 %>
        <% employer_share = plan.monthly_premium_cents.positive? ? ((plan.employer_contribution_cents.to_f / plan.monthly_premium_cents) * 100).round : 0 %>
        <article class="p-5">
          <div class="flex flex-col gap-5 xl:flex-row xl:items-start xl:justify-between">
            <div class="min-w-0 flex-1">
              <div class="flex flex-wrap items-center gap-2">
                <%= status_pill(plan.review_status) %>
                <%= status_pill(plan.readiness_status) %>
                <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= plan.plan_year || "Year pending" %></span>
              </div>
              <h3 class="mt-3 text-lg font-semibold text-slate-950"><%= plan.name %></h3>
              <p class="mt-1 text-sm text-slate-500"><%= plan.category.humanize %> · <%= plan.carrier.presence || "Carrier pending" %> · <%= plan.eligibility_rule.humanize %></p>

              <div class="mt-5 h-3 overflow-hidden rounded-full bg-slate-100">
                <div class="h-full bg-cyan-500" style="width: <%= [employee_share, 100].min %>%"></div>
                <div class="-mt-3 h-full bg-emerald-500" style="margin-left: <%= [employee_share, 100].min %>%; width: <%= [[employer_share, 100 - employee_share].min, 0].max %>%"></div>
              </div>
              <div class="mt-3 grid gap-3 sm:grid-cols-3">
                <div class="rounded-md bg-slate-50 p-3">
                  <p class="text-xs font-medium text-slate-500">Premium</p>
                  <p class="mt-1 font-semibold text-slate-950"><%= money_cents(plan.monthly_premium_cents) %></p>
                </div>
                <div class="rounded-md bg-cyan-50 p-3">
                  <p class="text-xs font-medium text-cyan-700">Employee</p>
                  <p class="mt-1 font-semibold text-cyan-950"><%= money_cents(plan.employee_contribution_cents) %></p>
                </div>
                <div class="rounded-md bg-emerald-50 p-3">
                  <p class="text-xs font-medium text-emerald-700">Employer</p>
                  <p class="mt-1 font-semibold text-emerald-950"><%= money_cents(plan.employer_contribution_cents) %></p>
                </div>
              </div>
            </div>

            <div class="w-full shrink-0 xl:w-72">
              <div class="rounded-md border border-slate-200 bg-slate-50 p-4">
                <div class="flex items-center justify-between gap-3">
                  <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Enrollment</p>
                  <%= status_pill(plan.status) %>
                </div>
                <div class="mt-4 grid grid-cols-2 gap-3">
                  <div>
                    <p class="text-xs text-slate-500">Accepted</p>
                    <p class="mt-1 text-xl font-semibold text-slate-950"><%= compact_number(plan.accepted_enrollment_count) %></p>
                  </div>
                  <div>
                    <p class="text-xs text-slate-500">Pending</p>
                    <p class="mt-1 text-xl font-semibold text-slate-950"><%= compact_number(plan.pending_enrollment_count) %></p>
                  </div>
                </div>
                <p class="mt-4 truncate font-mono text-xs text-slate-500"><%= plan.vitable_id.presence || "remote id pending" %></p>
                <div class="mt-4">
                  <% if plan.review_status != "published" && plan.publishable? %>
                    <%= button_to "Publish plan", publish_benefit_plan_path(plan.id), method: :post, params: { published_by: "benefits_admin" }, class: "w-full rounded-md bg-slate-950 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
                  <% elsif plan.review_status == "published" %>
                    <p class="rounded-md bg-white px-3 py-2 text-center text-sm font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-200">Published</p>
                  <% else %>
                    <p class="rounded-md bg-white px-3 py-2 text-center text-sm font-semibold text-amber-700 ring-1 ring-inset ring-amber-200">Resolve issues first</p>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Readiness issues</h2>
        <p class="text-sm text-slate-500">Plan data and contribution problems blocking a clean catalog sync.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @plan_admin.issues.each do |issue| %>
          <div class="p-5">
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= issue.reason_code.humanize %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.plan_name %></h3>
              </div>
              <%= status_pill(issue.severity) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
          </div>
        <% end %>
        <% if @plan_admin.issues.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">All plan designs are ready for catalog sync.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Catalog packet lines</h2>
        <p class="text-sm text-slate-500">Ready plans from the latest generated packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @plan_admin.packet_lines.each do |line| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= line.plan_name %></p>
              <p class="mt-1 text-sm text-slate-500"><%= line.category.humanize %> · <%= line.remote_action.humanize %> remote plan</p>
            </div>
            <div class="text-right">
              <%= status_pill(line.status) %>
              <p class="mt-2 text-sm font-semibold text-slate-950"><%= money_cents(line.monthly_premium_cents) %></p>
            </div>
          </div>
        <% end %>
        <% if @plan_admin.packet_lines.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">Generate a packet after publishing ready plans.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Packet holdbacks</h2>
      <p class="text-sm text-slate-500">Persisted holdbacks from the latest generated plan catalog packet.</p>
    </div>
    <div class="divide-y divide-slate-100">
      <% @plan_admin.packet_holdbacks.each do |issue| %>
        <div class="flex items-start justify-between gap-4 px-5 py-4">
          <div class="min-w-0">
            <p class="font-semibold text-slate-950"><%= issue.plan_name %></p>
            <p class="mt-1 text-sm text-slate-500"><%= issue.reason %></p>
          </div>
          <%= status_pill(issue.severity) %>
        </div>
      <% end %>
      <% if @plan_admin.packet_holdbacks.empty? %>
        <p class="px-5 py-5 text-sm text-slate-500">No packet holdbacks have been captured yet.</p>
      <% end %>
    </div>
  </section>
</section>
