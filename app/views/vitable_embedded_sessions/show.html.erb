<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.2fr_0.8fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@sessions.latest_packet&.status || "pending") %>
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800 ring-1 ring-inset ring-emerald-200">Employee-bound tokens</span>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Embedded enrollment</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Embedded enrollment sessions</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Prepare and issue short-lived Vitable access sessions bound to employees, with no-token storage, readiness holdbacks, and credential-aware audit trails for <%= @sessions.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate session packet", generate_vitable_embedded_sessions_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= link_to "Eligibility sync", benefits_eligibility_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Census sync", vitable_census_sync_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Partner docs", @sessions.ruby_docs_url, target: "_blank", rel: "noopener", class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Latest session packet</p>
        <% if @sessions.latest_packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @sessions.latest_packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@sessions.latest_packet.generated_at) %> ago by <%= operator_name(@sessions.latest_packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Ready</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@sessions.latest_packet.ready_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Pending elections</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@sessions.latest_packet.pending_election_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Token endpoint</p>
            <p class="mt-2 break-all font-mono text-xs text-slate-600"><%= @sessions.latest_packet.endpoint %></p>
            <p class="mt-2 text-xs text-slate-400"><%= @sessions.latest_packet.enrollment_widget.humanize %> widget mode</p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate a packet to see which employees can receive bound embedded enrollment sessions.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @sessions.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold text-slate-950">
          <%= metric.format == "number" ? compact_number(metric.value) : metric.value %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Issue preflight</h2>
        <p class="text-sm text-slate-500">Checks that decide whether employee-bound token issuance can proceed.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @sessions.preflight_checks.each do |check| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= check.label %></p>
              <p class="mt-1 break-words text-sm text-slate-500"><%= check.detail %></p>
            </div>
            <%= status_pill(check.status) %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Token attempts</h2>
        <p class="text-sm text-slate-500">Employee-bound token requests recorded without storing token secrets.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @sessions.token_runs.each do |sync| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= sync.operation.humanize %> <%= sync.resource_type %></p>
              <p class="mt-1 text-sm text-slate-500"><%= sync.started_at&.strftime("%b %-d, %I:%M %p") || "n/a" %></p>
              <% if sync.error_message.present? %>
                <p class="mt-1 break-words text-xs text-rose-600"><%= sync.error_message %></p>
              <% end %>
            </div>
            <%= status_pill(sync.status) %>
          </div>
        <% end %>
        <% if @sessions.token_runs.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No embedded enrollment token attempts have been recorded yet.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Session-ready employees</h2>
      <p class="text-sm text-slate-500">Employees with Vitable IDs and active elections eligible for employee-bound access tokens.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Plans</th>
            <th class="px-5 py-3">Elections</th>
            <th class="px-5 py-3">Remote employee</th>
            <th class="px-5 py-3">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @sessions.employees.each do |employee| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to employee.employee_name, employee_path(employee.employee_id), class: "font-semibold text-slate-950 hover:text-emerald-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= employee.department_name %> · <%= employee.location_name %></p>
                <p class="mt-1 break-all text-xs text-slate-400"><%= employee.email %></p>
              </td>
              <td class="px-5 py-4 text-slate-600">
                <%= employee.plan_names.to_sentence.presence || "No plans" %>
                <p class="mt-1 text-xs text-slate-500"><%= compact_number(employee.enrollment_ids.count) %> enrollment records</p>
              </td>
              <td class="px-5 py-4 text-slate-600">
                <%= compact_number(employee.pending_enrollment_count) %> pending
                <p class="mt-1 text-xs text-slate-500"><%= compact_number(employee.accepted_enrollment_count) %> accepted · <%= employee.next_effective_on&.strftime("%b %-d") || "effective date pending" %></p>
              </td>
              <td class="px-5 py-4">
                <%= status_pill(employee.status) %>
                <p class="mt-1 max-w-40 truncate font-mono text-xs text-slate-500"><%= employee.remote_employee_id %></p>
                <div class="mt-2"><%= status_pill(employee.session_status) %></div>
                <% if employee.session_expires_at.present? %>
                  <p class="mt-1 text-xs text-slate-500"><%= employee.session_active? ? "Expires #{time_ago_in_words(employee.session_expires_at)} from now" : "Expired #{time_ago_in_words(employee.session_expires_at)} ago" %></p>
                <% else %>
                  <p class="mt-1 text-xs text-slate-500">No issued session</p>
                <% end %>
              </td>
              <td class="px-5 py-4">
                <%= button_to "Issue session", issue_vitable_embedded_session_path(employee.employee_id), method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-slate-800" %>
              </td>
            </tr>
          <% end %>
          <% if @sessions.employees.empty? %>
            <tr>
              <td colspan="5" class="px-5 py-5 text-sm text-slate-500">Generate a packet to populate employees ready for embedded sessions.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Session holdbacks</h2>
        <p class="text-sm text-slate-500">Employees excluded until remote IDs or election state can support a bound token.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @sessions.holdbacks.each do |holdback| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= holdback.department_name %> · <%= holdback.location_name %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= holdback.employee_name %></h3>
              </div>
              <%= status_pill(holdback.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
            <p class="mt-2 text-xs text-slate-400"><%= holdback.plan_names.to_sentence %> · <%= holdback.reason_code %></p>
          </div>
        <% end %>
        <% if @sessions.holdbacks.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No holdbacks in the latest embedded session packet.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Session issuance activity</h2>
        <p class="text-sm text-slate-500">Session requests for embedded enrollment; token values are filtered before persistence.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @sessions.request_logs.each do |log| %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= log.method %> <%= log.path %></p>
                <p class="mt-1 text-sm text-slate-500"><%= log.operation %> · <%= log.duration_ms || 0 %>ms</p>
                <% if log.error_class.present? %>
                  <p class="mt-1 break-all text-xs text-rose-600"><%= log.error_class %></p>
                <% end %>
              </div>
              <%= status_pill(log.error_class.present? ? "failed" : "ready") %>
            </div>
          </div>
        <% end %>
        <% if @sessions.request_logs.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No session requests have been sent yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</section>
