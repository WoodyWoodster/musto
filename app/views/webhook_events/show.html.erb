<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.15fr_0.85fr]">
      <div class="p-6 lg:p-8">
        <%= link_to "Back to integrations", integrations_path, class: "text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
        <div class="mt-5 flex flex-wrap items-center gap-2">
          <%= status_pill(@webhook_event.status) %>
          <%= status_pill(@webhook_event.processed? ? "processed" : "received") %>
        </div>
        <h1 class="mt-5 break-all text-4xl font-semibold text-slate-950"><%= @webhook_event.event_name %></h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Review the event payload, routing match, delivery history, replay attempts, and API activity for <%= @webhook_event.resource_type.humanize.downcase %> <span class="font-mono text-sm"><%= @webhook_event.resource_id %></span>.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <%= button_to "Replay webhook", replay_webhook_event_path(@webhook_event.id), method: :post, params: { requested_by: "operations_console" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Refresh deliveries", refresh_deliveries_webhook_event_path(@webhook_event.id), method: :post, params: { requested_by: "operations_console" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
          <%= link_to "Webhook API", api_v1_webhooks_vitable_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Event identity</p>
        <div class="mt-6 space-y-5">
          <div>
            <p class="text-sm text-slate-600">Event ID</p>
            <p class="mt-1 break-all font-mono text-sm font-semibold"><%= @webhook_event.event_id %></p>
          </div>
          <div class="h-px bg-slate-200"></div>
          <div class="grid grid-cols-2 gap-4">
            <div>
              <p class="text-sm text-slate-600">Organization</p>
              <p class="mt-1 break-all font-semibold"><%= @webhook_event.organization_external_id %></p>
            </div>
            <div>
              <p class="text-sm text-slate-600">Occurred</p>
              <p class="mt-1 font-semibold"><%= @webhook_event.occurred_at.strftime("%b %-d, %I:%M %p") %></p>
            </div>
          </div>
          <% if @webhook_event.connection %>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Matched connection</p>
              <p class="mt-2 text-sm font-semibold text-slate-950"><%= @webhook_event.connection.organization_name %></p>
              <p class="mt-1 text-sm text-slate-600"><%= @webhook_event.connection.provider %> · <%= @webhook_event.connection.environment %></p>
            </div>
          <% else %>
            <div class="rounded-md bg-rose-500/10 p-4 text-rose-100">
              <p class="text-xs font-semibold uppercase">No connection matched</p>
              <p class="mt-2 text-sm leading-6">Replay after creating a matching Vitable connection for this organization external ID.</p>
            </div>
          <% end %>
        </div>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-5">
    <% [
      ["Resource", "#{@webhook_event.resource_type.humanize} #{@webhook_event.resource_id}", "bg-cyan-500"],
      ["Sync runs", @webhook_event.sync_runs.count, "bg-indigo-500"],
      ["API logs", @webhook_event.request_logs.count, "bg-amber-500"],
      ["Signature", @webhook_event.signature_status.humanize, "bg-pink-500"],
      ["Deliveries", @webhook_event.deliveries.count, "bg-violet-500"],
      ["Processed", @webhook_event.processed_at&.strftime("%b %-d, %I:%M %p") || "Not yet", "bg-emerald-500"]
    ].each do |label, value, accent| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <p class="text-sm font-medium text-slate-500"><%= label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= accent %>"></span>
        </div>
        <p class="mt-4 break-words text-lg font-semibold text-slate-950"><%= value %></p>
      </article>
    <% end %>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <div class="flex flex-col gap-2 md:flex-row md:items-start md:justify-between">
        <div>
          <h2 class="text-base font-semibold text-slate-950">Delivery attempts</h2>
          <p class="text-sm text-slate-500">Delivery records returned for this webhook event.</p>
        </div>
        <%= status_pill(@webhook_event.delivery_refreshed_at.present? ? "ready" : "pending") %>
      </div>
      <% if @webhook_event.delivery_status_counts.any? %>
        <div class="mt-4 flex flex-wrap gap-2">
          <% %w[delivered failed in_progress pending].each do |status| %>
            <% count = @webhook_event.delivery_status_counts.fetch(status, 0) %>
            <span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-600">
              <span><%= status.humanize %></span>
              <span class="font-mono text-slate-950"><%= compact_number(count) %></span>
            </span>
          <% end %>
        </div>
      <% end %>
    </div>
    <% if @webhook_event.deliveries.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Delivery</th>
              <th class="px-5 py-3">Subscription</th>
              <th class="px-5 py-3">Created</th>
              <th class="px-5 py-3">Completed</th>
              <th class="px-5 py-3">Status</th>
              <th class="px-5 py-3">Failure</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @webhook_event.deliveries.each do |delivery| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4">
                  <p class="break-all font-mono text-xs text-slate-700"><%= delivery.id %></p>
                  <p class="mt-1 break-all text-xs text-slate-400"><%= delivery.webhook_event_id %></p>
                </td>
                <td class="px-5 py-4 break-all font-mono text-xs text-slate-600"><%= delivery.subscription_id.presence || "n/a" %></td>
                <td class="px-5 py-4 text-slate-600"><%= delivery.created_at&.strftime("%b %-d, %I:%M %p") || "n/a" %></td>
                <td class="px-5 py-4 text-slate-600"><%= (delivery.delivered_at || delivery.failed_at || delivery.started_at)&.strftime("%b %-d, %I:%M %p") || "pending" %></td>
                <td class="px-5 py-4"><%= status_pill(delivery.status_key) %></td>
                <td class="px-5 py-4 text-slate-600"><%= delivery.failure_reason.presence || "none" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <% if @webhook_event.delivery_refreshed_at.present? %>
        <p class="border-t border-slate-100 px-5 py-3 text-xs text-slate-500">Refreshed <%= time_ago_in_words(@webhook_event.delivery_refreshed_at) %> ago.</p>
      <% end %>
    <% else %>
      <p class="px-5 py-5 text-sm text-slate-500">Refresh deliveries to inspect delivery attempts for this event.</p>
    <% end %>
  </section>

  <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Replay preflight</h2>
        <p class="text-sm text-slate-500">Checks used before replaying and fetching the referenced Vitable resource.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @webhook_event.preflight_checks.each do |check| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= check.label %></p>
              <p class="mt-1 break-all text-sm text-slate-500"><%= check.detail %></p>
            </div>
            <%= status_pill(check.status) %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-200 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Stored payload</h2>
        <p class="text-sm text-slate-400">Canonical payload used for replay and idempotency verification.</p>
      </div>
      <pre class="overflow-x-auto p-5 text-xs leading-6 text-slate-700"><%= JSON.pretty_generate(@webhook_event.payload) %></pre>
    </section>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.9fr_1.1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Event timeline</h2>
        <p class="text-sm text-slate-500">Webhook intake, replay, sync, and API activity for this resource.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @webhook_event.timeline.each do |item| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase text-slate-400"><%= item.type %></p>
              <p class="mt-1 break-all font-medium text-slate-950"><%= item.title %></p>
              <p class="mt-1 break-all text-sm text-slate-500"><%= item.subtitle %></p>
              <p class="mt-1 text-xs text-slate-400"><%= time_ago_in_words(item.timestamp) %> ago</p>
            </div>
            <%= status_pill(item.status) %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Sync attempts</h2>
        <p class="text-sm text-slate-500">Replay and resource fetch attempts connected to this event.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Operation</th>
              <th class="px-5 py-3">Resource</th>
              <th class="px-5 py-3">Started</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @webhook_event.sync_runs.each do |sync| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4 font-medium text-slate-950"><%= sync.operation.humanize %></td>
                <td class="px-5 py-4 text-slate-600"><%= sync.resource_type %></td>
                <td class="px-5 py-4 text-slate-600"><%= sync.started_at&.strftime("%b %-d, %I:%M %p") || "n/a" %></td>
                <td class="px-5 py-4"><%= status_pill(sync.status) %></td>
              </tr>
            <% end %>
            <% if @webhook_event.sync_runs.empty? %>
              <tr>
                <td colspan="4" class="px-5 py-5 text-sm text-slate-500">No matching attempts yet. Replay will record an attempt before fetching the resource.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Connection activity</h2>
      <p class="text-sm text-slate-500">Request attempts whose operation, path, or body reference this webhook resource.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Operation</th>
            <th class="px-5 py-3">Method</th>
            <th class="px-5 py-3">Path</th>
            <th class="px-5 py-3">Status</th>
            <th class="px-5 py-3">Duration</th>
            <th class="px-5 py-3">Error</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @webhook_event.request_logs.each do |log| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4 font-medium text-slate-950"><%= log.operation %></td>
              <td class="px-5 py-4 text-slate-600"><%= log.method %></td>
              <td class="px-5 py-4 font-mono text-xs text-slate-600"><span class="break-all"><%= log.path %></span></td>
              <td class="px-5 py-4 text-slate-600"><%= log.status_code || "n/a" %></td>
              <td class="px-5 py-4 text-slate-600"><%= log.duration_ms || 0 %>ms</td>
              <td class="px-5 py-4 text-slate-600"><%= log.error_class.presence || "none" %></td>
            </tr>
          <% end %>
          <% if @webhook_event.request_logs.empty? %>
            <tr>
              <td colspan="6" class="px-5 py-5 text-sm text-slate-500">No matching connection activity yet.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
