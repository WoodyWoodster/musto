<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.15fr_0.85fr]">
      <div class="p-6 lg:p-8">
        <%= link_to "Back to benefits", benefits_path, class: "text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
        <div class="mt-5 flex flex-wrap items-center gap-2">
          <%= status_pill(@reconciliation.exception_items.any? ? "needs_review" : "ready") %>
          <% if @reconciliation.payroll_run %>
            <%= status_pill(@reconciliation.payroll_run.status) %>
          <% end %>
        </div>
        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Benefits deduction reconciliation</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Compare enrollment decisions against the active payroll deductions before payroll is finalized. Exceptions can be repaired in place and then reviewed from payroll run detail.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          <% if @reconciliation.payroll_run %>
            <%= link_to "Open payroll run", payroll_run_path(@reconciliation.payroll_run.id), class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <% end %>
          <%= link_to "Billing", benefits_billing_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
          <%= link_to "Benefits cockpit", benefits_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Payroll context</p>
        <div class="mt-6 space-y-5">
          <div>
            <p class="text-sm text-slate-600">Employer</p>
            <p class="mt-1 break-words text-lg font-semibold"><%= @reconciliation.employer.name %></p>
          </div>
          <div class="h-px bg-slate-200"></div>
          <% if @reconciliation.payroll_run %>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <p class="text-sm text-slate-600">Pay date</p>
                <p class="mt-1 font-semibold"><%= @reconciliation.payroll_run.pay_date.strftime("%b %-d, %Y") %></p>
              </div>
              <div>
                <p class="text-sm text-slate-600">Deductions</p>
                <p class="mt-1 font-semibold"><%= money_cents(@reconciliation.payroll_run.total_deductions_cents) %></p>
              </div>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Run window</p>
              <p class="mt-2 text-sm font-semibold text-slate-950"><%= @reconciliation.payroll_run.period_start_on.strftime("%b %-d") %> - <%= @reconciliation.payroll_run.period_end_on.strftime("%b %-d, %Y") %></p>
            </div>
          <% else %>
            <div class="rounded-md bg-amber-500/10 p-4 text-amber-100">
              <p class="text-xs font-semibold uppercase">No payroll run</p>
              <p class="mt-2 text-sm leading-6">Resolving an exception will create a current estimated payroll run.</p>
            </div>
          <% end %>
        </div>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <% @reconciliation.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-4">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <%= status_pill(metric.status) %>
        </div>
        <p class="mt-4 break-words text-2xl font-semibold text-slate-950">
          <% if ["Expected deductions", "Variance"].include?(metric.label) %>
            <%= money_cents(metric.value) %>
          <% else %>
            <%= metric.value %>
          <% end %>
        </p>
      </article>
    <% end %>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Exception queue</h2>
      <p class="text-sm text-slate-500">Deductions whose amount, status, or presence does not match the enrollment decision.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Plan</th>
            <th class="px-5 py-3">Issue</th>
            <th class="px-5 py-3">Expected</th>
            <th class="px-5 py-3">Actual</th>
            <th class="px-5 py-3">Action</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @reconciliation.exception_items.each do |item| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to item.employee_name, employee_path(item.employee_id), class: "font-medium text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= item.coverage_level.humanize %> · <%= item.effective_on&.strftime("%b %-d, %Y") || "Pending" %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= link_to item.plan_name, enrollment_path(item.enrollment_id), class: "font-medium text-slate-700 hover:text-cyan-700" %></td>
              <td class="px-5 py-4">
                <p class="font-medium text-slate-950"><%= item.issue %></p>
                <div class="mt-1"><%= status_pill(item.severity) %></div>
              </td>
              <td class="px-5 py-4 text-slate-600">
                <p><%= money_cents(item.expected_amount_cents) %></p>
                <p class="mt-1 text-xs"><%= item.expected_status.humanize %></p>
              </td>
              <td class="px-5 py-4 text-slate-600">
                <p><%= money_cents(item.actual_amount_cents) %></p>
                <p class="mt-1 text-xs"><%= item.actual_status.humanize %></p>
              </td>
              <td class="px-5 py-4">
                <%= button_to "Resolve", resolve_benefits_reconciliation_item_path(item.enrollment_id), method: :post, class: "rounded-md bg-slate-950 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-slate-800" %>
              </td>
            </tr>
          <% end %>
          <% if @reconciliation.exception_items.empty? %>
            <tr>
              <td colspan="6" class="px-5 py-5 text-sm text-slate-500">No reconciliation exceptions. Benefits deductions match enrollment decisions.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Enrollment deduction ledger</h2>
      <p class="text-sm text-slate-500">Complete audit trail of expected versus actual payroll deduction state.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Enrollment</th>
            <th class="px-5 py-3">Expected amount</th>
            <th class="px-5 py-3">Actual amount</th>
            <th class="px-5 py-3">Delta</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @reconciliation.items.each do |item| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <p class="font-medium text-slate-950"><%= item.employee_name %></p>
                <p class="mt-1 text-xs text-slate-500"><%= item.plan_name %> · <%= item.enrollment_status.humanize %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(item.expected_amount_cents) %></td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(item.actual_amount_cents) %></td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(item.amount_delta_cents) %></td>
              <td class="px-5 py-4"><%= status_pill(item.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
