<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.18fr_0.82fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@changes.packet&.status || "pending") %>
          <span class="rounded-full bg-fuchsia-50 px-3 py-1 text-xs font-semibold text-fuchsia-800 ring-1 ring-inset ring-fuchsia-200">Pay changes</span>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Approval workflow</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Compensation change management</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Review raises, promotions, bonuses, and corrections for <%= @changes.employer&.name || "your employer portfolio" %>, then package approved changes for payroll and apply them to employee records.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate payroll packet", generate_compensation_change_packet_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= link_to "Comp planning", compensation_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Payroll", payroll_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Reports", reports_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-fuchsia-300">Latest pay-change packet</p>
        <% if @changes.packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @changes.packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@changes.packet.generated_at) %> ago by <%= operator_name(@changes.packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Changes</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@changes.packet.change_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@changes.packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Payroll run</p>
            <p class="mt-2 text-sm text-slate-600"><%= @changes.packet.payroll_run_id ? "Run ##{@changes.packet.payroll_run_id}" : "Run not assigned" %></p>
            <p class="mt-2 text-2xl font-semibold"><%= money_cents(@changes.packet.recurring_delta_cents + @changes.packet.one_time_cents) %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate a payroll packet after approving changes to see ready lines and holdbacks.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @changes.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold text-slate-950">
          <% if metric.format == "money" %>
            <%= money_cents(metric.value) %>
          <% elsif metric.format == "number" %>
            <%= compact_number(metric.value) %>
          <% else %>
            <%= metric.value %>
          <% end %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Review queue</h2>
        <p class="text-sm text-slate-500">Submitted and draft changes that need People and Finance approval.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @changes.reviewable_changes.each do |change| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= change.change_type.humanize %> · <%= change.department_name %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= change.employee_name %></h3>
                <p class="mt-2 text-sm leading-6 text-slate-600"><%= change.reason %></p>
              </div>
              <%= status_pill(change.status) %>
            </div>
            <div class="mt-4 grid gap-3 sm:grid-cols-3">
              <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs font-semibold uppercase text-slate-400">Current</p>
                <p class="mt-1 font-semibold text-slate-950"><%= money_cents(change.current_compensation_cents) %></p>
              </div>
              <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs font-semibold uppercase text-slate-400">Proposed</p>
                <p class="mt-1 font-semibold text-slate-950"><%= money_cents(change.proposed_compensation_cents) %></p>
              </div>
              <div class="rounded-md bg-slate-50 p-3">
                <p class="text-xs font-semibold uppercase text-slate-400">Delta</p>
                <p class="mt-1 font-semibold text-slate-950"><%= money_cents(change.delta_cents) %></p>
              </div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              <%= button_to "Approve", approve_compensation_change_path(change.id), method: :post, params: { approved_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-slate-800" %>
              <%= button_to "Reject", reject_compensation_change_path(change.id), method: :post, params: { reviewed_by: "Musto Operations", reason: "Rejected from compensation review" }, class: "rounded-md border border-slate-200 bg-white px-3 py-2 text-xs font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
            </div>
          </div>
        <% end %>
        <% if @changes.reviewable_changes.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No pay changes are waiting for approval.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Approved changes</h2>
        <p class="text-sm text-slate-500">Approved changes can be applied to employee pay or converted into payroll adjustments.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @changes.approved_changes.each do |change| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= change.employee_name %></p>
              <p class="mt-1 text-sm text-slate-500"><%= change.change_type.humanize %> · Effective <%= change.effective_on.strftime("%b %-d, %Y") %></p>
              <p class="mt-1 text-sm font-semibold text-slate-950"><%= money_cents(change.delta_cents) %></p>
            </div>
            <div class="shrink-0 text-right">
              <%= status_pill(change.status) %>
              <%= button_to "Apply", apply_compensation_change_path(change.id), method: :post, params: { applied_by: "Musto Operations" }, class: "mt-3 rounded-md bg-slate-950 px-3 py-2 text-xs font-semibold text-white shadow-sm hover:bg-slate-800" %>
            </div>
          </div>
        <% end %>
        <% if @changes.approved_changes.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No approved compensation changes are waiting to apply.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Change ledger</h2>
      <p class="text-sm text-slate-500">The full pay-change audit trail across review, approval, rejection, and apply states.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Change</th>
            <th class="px-5 py-3">Effective</th>
            <th class="px-5 py-3">Current</th>
            <th class="px-5 py-3">Proposed</th>
            <th class="px-5 py-3">Delta</th>
            <th class="px-5 py-3">Readiness</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @changes.changes.each do |change| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to change.employee_name, employee_path(change.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= change.employee_title.presence || change.department_name %> · <%= change.location_name %></p>
              </td>
              <td class="px-5 py-4">
                <p class="font-semibold text-slate-800"><%= change.change_type.humanize %></p>
                <p class="mt-1 max-w-72 text-xs text-slate-500"><%= change.reason %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= change.effective_on.strftime("%b %-d, %Y") %></td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(change.current_compensation_cents) %></td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(change.proposed_compensation_cents) %></td>
              <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(change.delta_cents) %></td>
              <td class="px-5 py-4">
                <%= status_pill(change.readiness_status) %>
                <p class="mt-1 text-xs text-slate-500"><%= change.readiness_reason %></p>
              </td>
            </tr>
          <% end %>
          <% if @changes.changes.empty? %>
            <tr>
              <td colspan="7" class="px-5 py-5 text-sm text-slate-500">No compensation changes have been created yet.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Payroll packet lines</h2>
        <p class="text-sm text-slate-500">Approved changes ready to flow into payroll processing.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @changes.packet_lines.each do |line| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= line.department_name %> · <%= line.change_type.humanize %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= line.employee_name %></h3>
                <p class="mt-2 text-sm text-slate-500"><%= line.reason %></p>
              </div>
              <%= status_pill(line.status) %>
            </div>
            <p class="mt-4 text-2xl font-semibold text-slate-950"><%= money_cents(line.delta_cents) %></p>
            <p class="mt-1 text-xs text-slate-500"><%= line.base_pay_change ? "Base pay update" : "One-time payroll adjustment" %> · Run <%= line.payroll_run_id || "pending" %></p>
          </div>
        <% end %>
        <% if @changes.packet_lines.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">Generate a packet to populate payroll-ready compensation lines.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet holdbacks</h2>
        <p class="text-sm text-slate-500">Changes withheld from payroll packaging until review clears.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @changes.packet_holdbacks.each do |holdback| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= holdback.change_type.humanize %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= holdback.employee_name %></h3>
              </div>
              <%= status_pill(holdback.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
          </div>
        <% end %>
        <% if @changes.packet_holdbacks.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No holdbacks in the latest compensation change packet.</p>
        <% end %>
      </div>
    </section>
  </div>
</section>
