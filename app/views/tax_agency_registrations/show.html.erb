<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.2fr_0.8fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@registrations.packet&.status || "pending") %>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Payroll tax setup</span>
          <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-800 ring-1 ring-inset ring-emerald-200">Agency evidence</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Tax agency registrations</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Coordinate federal, state, local, and unemployment registrations, retain submission confirmation, and keep deposit schedules ready before payroll filings leave draft mode.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Tax filings", taxes_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Company setup", company_setup_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Payroll calendar", payroll_calendar_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= button_to "Generate registration packet", generate_tax_agency_registration_packet_path, method: :post, params: { requested_by: "Tax Team" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Latest registration packet</p>
        <% if @registrations.packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @registrations.packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@registrations.packet.generated_at) %> ago by <%= operator_name(@registrations.packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Ready</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@registrations.packet.ready_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@registrations.packet.holdback_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Jurisdictions</p>
            <p class="mt-2 text-2xl font-semibold"><%= compact_number(@registrations.packet.jurisdiction_count) %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate a packet after reviewing registration status and submission evidence.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @registrations.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold text-slate-950"><%= metric.format == "text" ? metric.value : compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="flex flex-wrap items-center justify-between gap-3 border-b border-slate-100 px-5 py-4">
        <div>
          <h2 class="text-base font-semibold text-slate-950">Registration queue</h2>
          <p class="text-sm text-slate-500">Agency setup records with due dates, deposit schedules, owners, and submission evidence.</p>
        </div>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= compact_number(@registrations.registrations.count) %> records</span>
      </div>
      <div class="divide-y divide-slate-100">
        <% @registrations.registrations.each do |registration| %>
          <article class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= registration.jurisdiction %> · <%= registration.registration_type.humanize %></p>
                <h3 class="mt-2 text-lg font-semibold text-slate-950"><%= registration.agency_name %></h3>
                <p class="mt-1 text-sm leading-6 text-slate-600"><%= registration.notes.presence || "No registration notes recorded." %></p>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <%= status_pill(registration.risk_level) %>
                <%= status_pill(registration.status) %>
              </div>
            </div>

            <div class="mt-5 grid gap-3 md:grid-cols-4">
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase text-slate-400">Due</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= registration.due_on.strftime("%b %-d, %Y") %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase text-slate-400">Deposit</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= registration.deposit_schedule.humanize %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase text-slate-400">Account</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= registration.account_number.presence || "Pending" %></p>
              </div>
              <div class="rounded-md bg-slate-50 px-3 py-3">
                <p class="text-xs font-semibold uppercase text-slate-400">Owner</p>
                <p class="mt-1 text-sm font-semibold text-slate-950"><%= registration.owner %></p>
              </div>
            </div>

            <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-slate-100 pt-4">
              <p class="text-sm text-slate-500">
                <%= registration.location_name.presence || "Entity-level registration" %>
                <% if registration.remote %>
                  <span class="font-semibold text-cyan-700"> · remote workforce</span>
                <% end %>
                <% if registration.submitted_at.present? %>
                  <span> · submitted <%= registration.submitted_at.strftime("%b %-d, %Y") %></span>
                <% end %>
              </p>
              <% if registration.submittable %>
                <%= button_to "Submit registration", submit_tax_agency_registration_path(registration.id), method: :post, params: { submitted_by: "Tax Team" }, class: "rounded-md bg-cyan-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-cyan-700" %>
              <% else %>
                <span class="rounded-md border border-slate-200 bg-white px-3.5 py-2 text-sm font-semibold text-slate-600">Evidence retained</span>
              <% end %>
            </div>
          </article>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Registration blockers</h2>
        <p class="text-sm text-slate-500">Operational issues that can prevent payroll tax deposits or filings from clearing review.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @registrations.issues.any? %>
          <% @registrations.issues.each do |issue| %>
            <div class="p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="min-w-0">
                  <p class="text-xs font-semibold uppercase text-slate-400"><%= issue.jurisdiction %> · <%= issue.severity %></p>
                  <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.reason_code.humanize %></h3>
                </div>
                <%= status_pill(issue.status) %>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= issue.reason %></p>
              <p class="mt-3 text-xs font-semibold uppercase text-slate-400"><%= issue.owner %> · due <%= issue.due_on.strftime("%b %-d") %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5">
            <%= status_pill("ready") %>
            <p class="mt-3 text-sm leading-6 text-slate-600">All registration records have submission evidence and no active holdbacks.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Jurisdiction registration matrix</h2>
      <p class="text-sm text-slate-500">A compact review table for payroll operations and finance approval.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Agency</th>
            <th class="px-5 py-3">Jurisdiction</th>
            <th class="px-5 py-3">Type</th>
            <th class="px-5 py-3">Account</th>
            <th class="px-5 py-3">Schedule</th>
            <th class="px-5 py-3">Next deposit</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @registrations.registrations.each do |registration| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4 font-semibold text-slate-950"><%= registration.agency_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= registration.jurisdiction %></td>
              <td class="px-5 py-4 text-slate-600"><%= registration.registration_type.humanize %></td>
              <td class="px-5 py-4 text-slate-600"><%= registration.account_number.presence || "Pending" %></td>
              <td class="px-5 py-4 text-slate-600"><%= registration.deposit_schedule.humanize %></td>
              <td class="px-5 py-4 text-slate-600"><%= registration.next_deposit_due_on&.strftime("%b %-d, %Y") || "After registration" %></td>
              <td class="px-5 py-4"><%= status_pill(registration.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet registration lines</h2>
        <p class="text-sm text-slate-500">Generated audit evidence retained on employer settings for review or export.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @registrations.packet_lines.any? %>
          <% @registrations.packet_lines.each do |line| %>
            <div class="grid gap-4 px-5 py-4 md:grid-cols-[1fr_auto] md:items-center">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <p class="font-semibold text-slate-950"><%= line.agency_name %></p>
                  <%= status_pill(line.status) %>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= line.jurisdiction %> · <%= line.registration_type.humanize %> · <%= line.confirmation_number.presence || "confirmation pending" %></p>
              </div>
              <p class="text-sm font-semibold text-slate-950"><%= line.due_on.strftime("%b %-d") %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5">
            <p class="text-sm leading-6 text-slate-600">No packet lines yet. Generate a registration packet after reviewing the queue.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Packet holdbacks</h2>
        <p class="text-sm text-slate-500">Registration issues captured at packet generation time.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @registrations.packet_holdbacks.any? %>
          <% @registrations.packet_holdbacks.each do |holdback| %>
            <div class="p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase text-slate-400"><%= holdback.jurisdiction %> · <%= holdback.severity %></p>
                  <h3 class="mt-2 text-base font-semibold text-slate-950"><%= holdback.reason_code.humanize %></h3>
                </div>
                <%= status_pill(holdback.status) %>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5">
            <p class="text-sm leading-6 text-slate-600">Holdbacks will appear here after packet generation.</p>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</section>
