<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.25fr_0.75fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@compensation.generated? ? @compensation.latest_packet.status : "pending") %>
          <span class="rounded-full bg-fuchsia-50 px-3 py-1 text-xs font-semibold text-fuchsia-800 ring-1 ring-inset ring-fuchsia-200">Compensation review</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Budget-aware</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Compensation planning center</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Align employee pay, department budgets, benefit load, and payroll adjustments before exporting a compensation review packet for <%= @compensation.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= link_to "Workforce", workforce_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Payroll", payroll_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Reports", reports_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= button_to "Generate packet", generate_compensation_packet_path, method: :post, params: { requested_by: "ops_console" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-fuchsia-300">Latest packet</p>
        <% if @compensation.latest_packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @compensation.latest_packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-300">Generated <%= time_ago_in_words(@compensation.latest_packet.generated_at) %> ago by <%= @compensation.latest_packet.requested_by %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Employees</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@compensation.latest_packet.employee_count) %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Reviews</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@compensation.latest_packet.recommendation_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md bg-white/10 p-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Annual payroll</p>
            <p class="mt-2 text-2xl font-semibold"><%= money_cents(@compensation.latest_packet.annual_compensation_cents) %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Generate a compensation packet once the pay plan is ready for finance review.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @compensation.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950"><%= metric.format == "money" ? money_cents(metric.value) : compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.15fr_0.85fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Department budget exposure</h2>
        <p class="text-sm text-slate-500">Annual compensation, adjustment, and benefit load against department budgets.</p>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
            <tr>
              <th class="px-5 py-3">Department</th>
              <th class="px-5 py-3">People</th>
              <th class="px-5 py-3">Budget</th>
              <th class="px-5 py-3">Planned</th>
              <th class="px-5 py-3">Remaining</th>
              <th class="px-5 py-3">Utilization</th>
              <th class="px-5 py-3">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @compensation.departments.each do |department| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4">
                  <p class="font-semibold text-slate-950"><%= department.department_name %></p>
                  <p class="mt-1 text-xs text-slate-500"><%= department.code %></p>
                </td>
                <td class="px-5 py-4 text-slate-600"><%= compact_number(department.employee_count) %></td>
                <td class="px-5 py-4 text-slate-600"><%= money_cents(department.budget_cents) %></td>
                <td class="px-5 py-4 text-slate-600"><%= money_cents(department.planned_spend_cents) %></td>
                <td class="px-5 py-4 font-medium <%= department.remaining_cents.negative? ? "text-rose-700" : "text-slate-700" %>"><%= money_cents(department.remaining_cents) %></td>
                <td class="px-5 py-4">
                  <div class="min-w-28">
                    <div class="h-2 overflow-hidden rounded-full bg-slate-100">
                      <div class="h-2 rounded-full <%= department.status == "blocked" ? "bg-rose-500" : "bg-cyan-500" %>" style="width: <%= [department.utilization_percent, 100].min %>%"></div>
                    </div>
                    <p class="mt-1 text-xs font-semibold text-slate-500"><%= department.utilization_percent %>%</p>
                  </div>
                </td>
                <td class="px-5 py-4"><%= status_pill(department.status) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Planning recommendations</h2>
        <p class="text-sm text-slate-500">The items that should be cleared before a packet is shared.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @compensation.recommendations.each do |recommendation| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= recommendation.owner %> · <%= recommendation.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= recommendation.title %></h3>
              </div>
              <%= status_pill(recommendation.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= recommendation.detail %></p>
            <%= link_to "Open source workflow", recommendation.action_path, class: "mt-4 inline-flex text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Employee compensation</h2>
      <p class="text-sm text-slate-500">Active employees with annual base pay, annualized Vitable benefit load, payroll adjustments, and packet readiness.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Department</th>
            <th class="px-5 py-3">Location</th>
            <th class="px-5 py-3">Base pay</th>
            <th class="px-5 py-3">Benefits</th>
            <th class="px-5 py-3">Adjustments</th>
            <th class="px-5 py-3">Planned</th>
            <th class="px-5 py-3">Readiness</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @compensation.employees.each do |employee| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to employee.employee_name, employee_path(employee.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= employee.title.presence || employee.pay_type.humanize %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= employee.department_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= employee.location_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(employee.base_compensation_cents) %></td>
              <td class="px-5 py-4">
                <p class="text-slate-600"><%= money_cents(employee.annual_benefit_cents) %></p>
                <p class="mt-1 text-xs text-slate-500"><%= employee.accepted_enrollment_count %> accepted · <%= employee.pending_enrollment_count %> pending</p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(employee.adjustment_cents) %></td>
              <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(employee.total_planned_cents) %></td>
              <td class="px-5 py-4">
                <%= status_pill(employee.status) %>
                <p class="mt-1 text-xs text-slate-500"><%= employee.status_reason %></p>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Adjustment review</h2>
      <p class="text-sm text-slate-500">Bonuses, reimbursements, corrections, and taxable flags flowing into compensation planning.</p>
    </div>
    <div class="grid divide-y divide-slate-100 lg:grid-cols-3 lg:divide-x lg:divide-y-0">
      <% @compensation.adjustments.first(6).each do |adjustment| %>
        <article class="p-5">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="min-w-0">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= adjustment.adjustment_type.humanize %></p>
              <h3 class="mt-2 text-base font-semibold text-slate-950"><%= adjustment.description %></h3>
            </div>
            <%= status_pill(adjustment.status) %>
          </div>
          <p class="mt-4 text-2xl font-semibold tracking-tight text-slate-950"><%= money_cents(adjustment.amount_cents) %></p>
          <p class="mt-2 text-sm text-slate-500"><%= adjustment.employee_name %> · <%= adjustment.department_name %></p>
          <p class="mt-1 text-xs text-slate-500"><%= adjustment.taxable? ? "Taxable" : "Non-taxable" %> · Pay date <%= adjustment.pay_date.strftime("%b %-d, %Y") %></p>
        </article>
      <% end %>

      <% if @compensation.adjustments.empty? %>
        <div class="p-5">
          <p class="font-semibold text-slate-950">No adjustment lines</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Payroll adjustments will appear here once a run includes bonuses, reimbursements, or corrections.</p>
        </div>
      <% end %>
    </div>
  </section>
</section>
