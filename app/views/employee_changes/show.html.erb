<% latest_batch = @employee_changes.latest_batch %>

<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.18fr_0.82fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@employee_changes.reviewable_requests.any? ? "needs_review" : "ready") %>
          <span class="rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-800 ring-1 ring-inset ring-sky-200">Employee portal</span>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Profile sync</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Employee self-service inbox</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Review employee-submitted profile, tax, emergency contact, work-location, and direct deposit changes for <%= @employee_changes.employer&.name || "your employer portfolio" %>.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate profile sync", generate_employee_changes_sync_batch_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= link_to "Workforce", workforce_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Documents", documents_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Payroll funding", payroll_funding_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Eligibility", benefits_eligibility_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-sky-300">Latest profile sync</p>
        <% if latest_batch.present? %>
          <div class="mt-6 flex flex-wrap items-center gap-2">
            <%= status_pill(latest_batch.status) %>
            <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-200">Generated <%= time_ago_in_words(latest_batch.generated_at) %> ago</span>
          </div>
          <p class="mt-4 break-all font-mono text-sm font-semibold"><%= latest_batch.batch_id %></p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Requested by <%= operator_name(latest_batch.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Requests</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(latest_batch.request_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Employees</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(latest_batch.employee_count) %></p>
            </div>
          </div>
          <div class="mt-5 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Payroll</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(latest_batch.payroll_impact_count) %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Held</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(latest_batch.holdback_count) %></p>
            </div>
          </div>
        <% else %>
          <p class="mt-6 text-5xl font-semibold"><%= compact_number(@employee_changes.reviewable_requests.count) %></p>
          <p class="mt-2 text-sm leading-6 text-slate-600">requests are waiting for People Ops review before local records change.</p>
          <div class="mt-6 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Applied locally</p>
            <p class="mt-2 text-2xl font-semibold"><%= compact_number(@employee_changes.applied_requests.count) %></p>
            <p class="mt-1 text-sm text-slate-600">ready for sync packaging</p>
          </div>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @employee_changes.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold text-slate-950"><%= compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <section class="space-y-4">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="text-lg font-semibold text-slate-950">Self-service lanes</h2>
        <p class="text-sm text-slate-500">Request mix by employee workflow and downstream operating impact.</p>
      </div>
      <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold text-slate-600 ring-1 ring-slate-200"><%= compact_number(@employee_changes.requests.count) %> total requests</span>
    </div>

    <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-5">
      <% @employee_changes.type_summaries.each do |summary| %>
        <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase text-slate-400"><%= summary.request_type %></p>
              <h3 class="mt-2 text-base font-semibold text-slate-950"><%= summary.label %></h3>
            </div>
            <span class="h-3 w-3 shrink-0 rounded-full <%= summary.accent %>"></span>
          </div>
          <p class="mt-5 text-3xl font-semibold text-slate-950"><%= compact_number(summary.request_count) %></p>
          <div class="mt-3 flex flex-wrap items-center gap-2">
            <%= status_pill(summary.status) %>
            <span class="text-xs font-semibold text-slate-500"><%= compact_number(summary.submitted_count) %> review · <%= compact_number(summary.applied_count) %> applied</span>
          </div>
        </article>
      <% end %>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1.12fr_0.88fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Review queue</h2>
        <p class="text-sm text-slate-500">Approve and apply employee-submitted changes or reject requests with an audit reason.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @employee_changes.reviewable_requests.each do |request| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-4">
              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-2">
                  <%= link_to request.employee_name, employee_path(request.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                  <%= status_pill(request.status) %>
                  <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700"><%= request.request_type.humanize %></span>
                </div>
                <p class="mt-1 text-sm text-slate-500"><%= request.department_name || "Unassigned" %> · <%= request.location_name || "No location" %> · effective <%= request.effective_on.strftime("%b %-d, %Y") %></p>
                <h3 class="mt-3 text-base font-semibold text-slate-950"><%= request.title %></h3>
                <p class="mt-2 text-sm leading-6 text-slate-600"><%= request.summary.presence || request.payload_preview %></p>
                <div class="mt-3 flex flex-wrap gap-2">
                  <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">Payroll: <%= request.payroll_impact.humanize %></span>
                  <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">Benefits: <%= request.benefits_impact.humanize %></span>
                  <span class="rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600">Compliance: <%= request.compliance_impact.humanize %></span>
                </div>
              </div>
              <div class="text-right">
                <%= status_pill(request.remote_employee_id.present? ? "synced" : "remote_pending") %>
                <p class="mt-1 max-w-40 truncate text-xs text-slate-500"><%= request.remote_employee_id.presence || "Create on sync" %></p>
              </div>
            </div>
            <div class="mt-5 flex flex-wrap gap-3">
              <%= button_to "Approve and apply", approve_employee_change_request_path(request.id), method: :post, params: { reviewed_by: "Musto Operations" }, class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
              <%= button_to "Reject", reject_employee_change_request_path(request.id), method: :post, params: { reviewed_by: "Musto Operations", reason: "Rejected from self-service review" }, class: "rounded-md border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
            </div>
          </div>
        <% end %>

        <% if @employee_changes.reviewable_requests.empty? %>
          <div class="p-5">
            <p class="font-semibold text-slate-950">No requests need review</p>
            <p class="mt-2 text-sm leading-6 text-slate-600">Employee-submitted changes will appear here before they update payroll, benefits, or profile records.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Impact checks</h2>
        <p class="text-sm text-slate-500">Payroll, benefits, compliance, and integration checks triggered by employee changes.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @employee_changes.impact_items.each do |item| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= item.owner %> · <%= item.severity %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= item.title %></h3>
              </div>
              <%= status_pill(item.status) %>
            </div>
            <p class="mt-3 text-sm leading-6 text-slate-600"><%= item.detail %></p>
            <%= link_to "Open workflow", item.action_path, class: "mt-4 inline-flex text-sm font-semibold text-cyan-700 hover:text-cyan-900" %>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Employee change ledger</h2>
      <p class="text-sm text-slate-500">Full audit trail of self-service requests, review status, payload summary, and downstream impact.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Request</th>
            <th class="px-5 py-3">Effective</th>
            <th class="px-5 py-3">Payload</th>
            <th class="px-5 py-3">Impact</th>
            <th class="px-5 py-3">Readiness</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @employee_changes.requests.each do |request| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to request.employee_name, employee_path(request.employee_id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="mt-1 text-xs text-slate-500"><%= request.employee_title.presence || "Role pending" %></p>
              </td>
              <td class="px-5 py-4">
                <p class="font-medium text-slate-700"><%= request.title %></p>
                <p class="mt-1 text-xs text-slate-500"><%= request.request_type.humanize %> · submitted <%= request.submitted_at.strftime("%b %-d") %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= request.effective_on.strftime("%b %-d, %Y") %></td>
              <td class="px-5 py-4 text-slate-600"><p class="max-w-64 truncate"><%= request.payload_preview %></p></td>
              <td class="px-5 py-4 text-slate-600"><%= request.payroll_impact.humanize %> · <%= request.benefits_impact.humanize %></td>
              <td class="px-5 py-4">
                <%= status_pill(request.readiness_status) %>
                <p class="mt-1 max-w-52 text-xs text-slate-500"><%= request.readiness_reason %></p>
              </td>
              <td class="px-5 py-4"><%= status_pill(request.status) %></td>
            </tr>
          <% end %>
          <% if @employee_changes.requests.empty? %>
            <tr>
              <td colspan="7" class="px-5 py-5 text-sm text-slate-600">No employee change requests exist yet.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Profile sync ledger</h2>
      <p class="text-sm text-slate-500">Applied self-service changes and review holdbacks from the latest profile sync batch.</p>
    </div>
    <% if latest_batch.present? %>
      <div class="grid divide-y divide-slate-100 xl:grid-cols-[1fr_0.86fr] xl:divide-x xl:divide-y-0">
        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase text-slate-400">Queued changes</p>
          </div>
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-100 text-sm">
              <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
                <tr>
                  <th class="px-5 py-3">Employee</th>
                  <th class="px-5 py-3">Request</th>
                  <th class="px-5 py-3">Effective</th>
                  <th class="px-5 py-3">Impact</th>
                  <th class="px-5 py-3">Status</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100">
                <% @employee_changes.sync_lines.each do |line| %>
                  <tr class="hover:bg-slate-50">
                    <td class="px-5 py-4">
                      <p class="font-semibold text-slate-950"><%= line.employee_name %></p>
                      <p class="mt-1 max-w-44 truncate text-xs text-slate-500"><%= line.remote_employee_id %></p>
                    </td>
                    <td class="px-5 py-4 text-slate-600"><%= line.request_type.humanize %><p class="mt-1 max-w-56 truncate text-xs text-slate-500"><%= line.title %></p></td>
                    <td class="px-5 py-4 text-slate-600"><%= line.effective_on.strftime("%b %-d, %Y") %></td>
                    <td class="px-5 py-4 text-slate-600"><%= line.payroll_impact.humanize %> · <%= line.benefits_impact.humanize %></td>
                    <td class="px-5 py-4"><%= status_pill(line.status) %></td>
                  </tr>
                <% end %>
                <% if @employee_changes.sync_lines.empty? %>
                  <tr>
                    <td colspan="5" class="px-5 py-5 text-sm text-slate-600">No applied requests were included.</td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>

        <div class="min-w-0">
          <div class="border-b border-slate-100 px-5 py-3">
            <p class="text-xs font-semibold uppercase text-slate-400">Holdbacks</p>
          </div>
          <div class="divide-y divide-slate-100">
            <% @employee_changes.sync_holdbacks.each do |holdback| %>
              <div class="p-5">
                <div class="flex flex-wrap items-start justify-between gap-3">
                  <div class="min-w-0">
                    <p class="font-semibold text-slate-950"><%= holdback.employee_name %></p>
                    <p class="mt-1 text-sm text-slate-500"><%= holdback.request_type.humanize %></p>
                  </div>
                  <%= status_pill(holdback.status) %>
                </div>
                <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
              </div>
            <% end %>
            <% if @employee_changes.sync_holdbacks.empty? %>
              <div class="p-5">
                <p class="font-semibold text-slate-950">No holdbacks</p>
                <p class="mt-2 text-sm leading-6 text-slate-600">All applied self-service requests were included in the latest batch.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="p-5">
        <p class="font-semibold text-slate-950">No generated profile sync</p>
        <p class="mt-2 text-sm leading-6 text-slate-600">Applied employee requests and approval holdbacks will appear here after sync generation.</p>
      </div>
    <% end %>
  </section>
</section>
