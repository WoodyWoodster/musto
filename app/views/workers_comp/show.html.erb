<% policy = @workers_comp.policy %>
<% latest_packet = @workers_comp.latest_packet %>

<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid xl:grid-cols-[1.18fr_0.82fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(policy&.status || "missing") %>
          <span class="rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-800 ring-1 ring-inset ring-red-200">Workers comp</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Class-code audit</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950">Workers comp coverage</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Track coverage, class-code payroll exposure, open claims, carrier reserves, and audit packet readiness from one compliance workspace.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate audit packet", generate_workers_comp_audit_packet_path, method: :post, params: { requested_by: "compliance_ops" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= link_to "Compliance center", compliance_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Payroll", payroll_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Reports", reports_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-slate-950 p-6 text-white xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-red-300">Coverage snapshot</p>
        <% if policy.present? %>
          <p class="mt-6 text-3xl font-semibold tracking-tight"><%= policy.carrier %></p>
          <p class="mt-2 break-all font-mono text-sm text-slate-300"><%= policy.policy_number %></p>
          <div class="mt-5 flex flex-wrap items-center gap-2">
            <%= status_pill(policy.status) %>
            <% if policy.renewal_due %>
              <%= status_pill("renewal_due") %>
            <% end %>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Premium</p>
              <p class="mt-2 text-2xl font-semibold"><%= money_cents(policy.manual_premium_cents) %></p>
            </div>
            <div class="rounded-md bg-white/10 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Deposit</p>
              <p class="mt-2 text-2xl font-semibold"><%= money_cents(policy.deposit_premium_cents) %></p>
            </div>
          </div>
          <p class="mt-5 text-sm leading-6 text-slate-300">
            Coverage <%= policy.coverage_start_on.strftime("%b %-d, %Y") %> to <%= policy.coverage_end_on.strftime("%b %-d, %Y") %>. Renewal due <%= policy.renewal_due_on.strftime("%b %-d") %>.
          </p>
        <% else %>
          <p class="mt-6 text-3xl font-semibold tracking-tight">Policy missing</p>
          <p class="mt-2 text-sm leading-6 text-slate-300">Add active workers comp coverage before payroll audit packets are production-ready.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @workers_comp.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 text-3xl font-semibold tracking-tight text-slate-950"><%= metric.format == "money" ? money_cents(metric.value) : metric.format == "text" ? metric.value : compact_number(metric.value) %></p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1.05fr_0.95fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Audit readiness issues</h2>
        <p class="text-sm text-slate-500">Coverage, certificate, class-code, and claims issues that affect audit packet readiness.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @workers_comp.issues.any? %>
          <% @workers_comp.issues.each do |issue| %>
            <div class="p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= issue.severity %> · <%= issue.reason_code.humanize %></p>
                  <h3 class="mt-2 text-base font-semibold text-slate-950"><%= issue.reason %></h3>
                </div>
                <%= status_pill(issue.status) %>
              </div>
            </div>
          <% end %>
        <% else %>
          <div class="p-5">
            <%= status_pill("ready") %>
            <p class="mt-3 text-sm leading-6 text-slate-600">Coverage, class-code, and claims data are audit-ready.</p>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Open claims</h2>
        <p class="text-sm text-slate-500">Carrier claim status, reserve exposure, lost time, and return-to-work follow-up.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @workers_comp.claims.any? %>
          <% @workers_comp.claims.each do |claim| %>
            <div class="p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div class="min-w-0">
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= claim.severity.humanize %> · <%= claim.claim_number.presence || "Claim number pending" %></p>
                  <h3 class="mt-2 text-base font-semibold text-slate-950"><%= claim.employee_name %></h3>
                  <p class="mt-1 text-sm text-slate-500"><%= claim.injury_type.presence || "Injury type pending" %> · <%= claim.body_part.presence || "Body part pending" %></p>
                </div>
                <%= status_pill(claim.status) %>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= claim.description %></p>
              <div class="mt-4 grid gap-2 sm:grid-cols-3">
                <div class="rounded-md bg-slate-50 px-3 py-2">
                  <p class="text-xs text-slate-500">Reserve</p>
                  <p class="mt-1 font-semibold text-slate-950"><%= money_cents(claim.reserve_cents) %></p>
                </div>
                <div class="rounded-md bg-slate-50 px-3 py-2">
                  <p class="text-xs text-slate-500">Paid</p>
                  <p class="mt-1 font-semibold text-slate-950"><%= money_cents(claim.paid_cents) %></p>
                </div>
                <div class="rounded-md bg-slate-50 px-3 py-2">
                  <p class="text-xs text-slate-500">Lost time</p>
                  <p class="mt-1 font-semibold text-slate-950"><%= compact_number(claim.lost_time_days) %> days</p>
                </div>
              </div>
              <% if claim.closable? %>
                <div class="mt-4 border-t border-slate-100 pt-4">
                  <%= button_to "Close claim", close_workers_comp_claim_path(claim.id), method: :post, params: { closed_by: "compliance_ops", resolution: "Closed from workers comp center" }, class: "rounded-md bg-emerald-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                </div>
              <% end %>
            </div>
          <% end %>
        <% else %>
          <div class="p-5 text-sm leading-6 text-slate-600">No workers comp claims are currently tracked.</div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="flex flex-col gap-2 border-b border-slate-100 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Class-code payroll exposure</h2>
        <p class="text-sm text-slate-500">Annual payroll basis grouped by workers comp class code, service state, and modeled premium rate.</p>
      </div>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700"><%= compact_number(@workers_comp.exposures.count) %> exposure groups</span>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Class</th>
            <th class="px-5 py-3">State</th>
            <th class="px-5 py-3">Employees</th>
            <th class="px-5 py-3">Payroll basis</th>
            <th class="px-5 py-3">Rate</th>
            <th class="px-5 py-3">Premium</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @workers_comp.exposures.each do |line| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <p class="font-semibold text-slate-950"><%= line.class_code %></p>
                <p class="mt-1 text-xs text-slate-500"><%= line.class_description %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= line.service_state %></td>
              <td class="px-5 py-4 text-slate-600">
                <%= compact_number(line.employee_count) %>
                <p class="mt-1 max-w-72 truncate text-xs text-slate-500"><%= line.employee_names.join(", ") %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= money_cents(line.payroll_cents) %></td>
              <td class="px-5 py-4 text-slate-600"><%= line.rate_basis_points / 100.0 %>%</td>
              <td class="px-5 py-4 font-semibold text-slate-950"><%= money_cents(line.estimated_premium_cents) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1.1fr_0.9fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Audit packet exposure lines</h2>
        <p class="text-sm text-slate-500">Retained class-code lines from the latest workers comp audit packet.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @workers_comp.packet_lines.any? %>
          <% @workers_comp.packet_lines.each do |line| %>
            <div class="grid gap-4 px-5 py-4 md:grid-cols-[1fr_auto] md:items-center">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= line.class_code %> · <%= line.service_state %></p>
                <p class="mt-1 text-sm text-slate-500"><%= line.class_description %> · <%= compact_number(line.employee_count) %> employees</p>
              </div>
              <p class="text-sm font-semibold text-slate-950"><%= money_cents(line.estimated_premium_cents) %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5 text-sm leading-6 text-slate-600">Generate an audit packet to retain class-code exposure lines.</div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Audit packet holdbacks</h2>
        <p class="text-sm text-slate-500">Readiness issues captured at packet generation time.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% if @workers_comp.packet_holdbacks.any? %>
          <% @workers_comp.packet_holdbacks.each do |holdback| %>
            <div class="p-5">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-400"><%= holdback.severity %></p>
                  <h3 class="mt-2 text-base font-semibold text-slate-950"><%= holdback.reason_code.humanize %></h3>
                </div>
                <%= status_pill(holdback.status) %>
              </div>
              <p class="mt-3 text-sm leading-6 text-slate-600"><%= holdback.reason %></p>
            </div>
          <% end %>
        <% else %>
          <div class="p-5 text-sm leading-6 text-slate-600">Packet holdbacks will appear after packet generation.</div>
        <% end %>
      </div>
    </section>
  </div>
</section>
