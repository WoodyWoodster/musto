<section class="space-y-7">
  <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="grid gap-0 xl:grid-cols-[1.16fr_0.84fr]">
      <div class="p-6 lg:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <%= status_pill(@provisioning.latest_packet&.status || "pending") %>
          <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-800 ring-1 ring-inset ring-indigo-200">Employer create</span>
          <span class="rounded-full bg-violet-50 px-3 py-1 text-xs font-semibold text-violet-800 ring-1 ring-inset ring-violet-200">Eligibility policy</span>
          <span class="rounded-full bg-cyan-50 px-3 py-1 text-xs font-semibold text-cyan-800 ring-1 ring-inset ring-cyan-200">Settings sync</span>
        </div>

        <h1 class="mt-5 text-4xl font-semibold text-slate-950">Vitable employer provisioning</h1>
        <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
          Create or update the Vitable employer profile for <%= @provisioning.employer&.name || "your employer portfolio" %>, with legal-entity checks, remote eligibility policy setup, field review, submission readiness, and activity history before census sync starts.
        </p>

        <div class="mt-6 flex flex-wrap gap-3">
          <%= button_to "Generate packet", generate_vitable_employer_provisioning_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
          <%= button_to "Submit provisioning", submit_vitable_employer_provisioning_path, method: :post, params: { requested_by: "Musto Operations" }, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Vitable connection", @provisioning.connection_id ? integration_connection_path(@provisioning.connection_id) : integrations_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Census sync", vitable_census_sync_path, class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
          <%= link_to "Partner docs", @provisioning.ruby_docs_url, target: "_blank", rel: "noopener", class: "rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-800 shadow-sm hover:border-slate-300" %>
        </div>
      </div>

      <aside class="border-t border-slate-200 bg-[#f8fafc] p-6 text-slate-950 xl:border-l xl:border-t-0 xl:p-8">
        <p class="text-xs font-semibold uppercase text-slate-500">Latest provisioning packet</p>
        <% if @provisioning.latest_packet.present? %>
          <p class="mt-6 break-all font-mono text-sm font-semibold"><%= @provisioning.latest_packet.packet_id %></p>
          <p class="mt-3 text-sm text-slate-600">Generated <%= time_ago_in_words(@provisioning.latest_packet.generated_at) %> ago by <%= operator_name(@provisioning.latest_packet.requested_by) %></p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Mode</p>
              <p class="mt-2 text-2xl font-semibold"><%= @provisioning.latest_packet.mode.humanize %></p>
            </div>
            <div class="rounded-md border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase text-slate-400">Missing</p>
              <p class="mt-2 text-2xl font-semibold"><%= compact_number(@provisioning.latest_packet.missing_field_count) %></p>
            </div>
          </div>
          <div class="mt-5 rounded-md border border-slate-200 bg-white p-4">
            <p class="text-xs font-semibold uppercase text-slate-400">Endpoint</p>
            <p class="mt-2 break-all font-mono text-xs text-slate-600"><%= @provisioning.latest_packet.endpoint %></p>
            <p class="mt-2 break-all font-mono text-xs text-slate-400"><%= @provisioning.latest_packet.remote_employer_id.presence || "Remote employer ID will be assigned on create" %></p>
          </div>
        <% else %>
          <p class="mt-6 text-3xl font-semibold">No packet</p>
          <p class="mt-2 text-sm leading-6 text-slate-600">Generate a provisioning packet to lock the current employer fields before submit.</p>
        <% end %>
      </aside>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
    <% @provisioning.metrics.each do |metric| %>
      <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between gap-3">
          <p class="text-sm font-medium text-slate-500"><%= metric.label %></p>
          <span class="h-2.5 w-2.5 shrink-0 rounded-full <%= metric.accent %>"></span>
        </div>
        <p class="mt-4 break-words text-3xl font-semibold text-slate-950">
          <%= metric.format == "number" ? compact_number(metric.value) : metric.value %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-2">
          <%= status_pill(metric.status) %>
          <p class="text-sm text-slate-500"><%= metric.hint %></p>
        </div>
      </article>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[0.92fr_1.08fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Provisioning preflight</h2>
        <p class="text-sm text-slate-500">Checks that decide whether employer create or settings update can be submitted.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @provisioning.preflight_checks.each do |check| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= check.label %></p>
              <p class="mt-1 break-words text-sm text-slate-500"><%= check.detail %></p>
            </div>
            <%= status_pill(check.status) %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Provisioning attempts</h2>
        <p class="text-sm text-slate-500">Employer, settings, and eligibility-policy attempts captured with connection readiness state.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @provisioning.sync_runs.each do |sync| %>
          <div class="flex items-start justify-between gap-4 px-5 py-4">
            <div class="min-w-0">
              <p class="font-semibold text-slate-950"><%= sync.operation.humanize %> <%= sync.resource_type %></p>
              <p class="mt-1 text-sm text-slate-500"><%= sync.started_at&.strftime("%b %-d, %I:%M %p") || "n/a" %></p>
              <% if sync.error_message.present? %>
                <p class="mt-1 break-words text-xs text-rose-600"><%= sync.error_message %></p>
              <% end %>
            </div>
            <%= status_pill(sync.status) %>
          </div>
        <% end %>
        <% if @provisioning.sync_runs.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No employer provisioning attempts have been recorded yet.</p>
        <% end %>
      </div>
    </section>
  </div>

  <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Submission field review</h2>
      <p class="text-sm text-slate-500">Employer profile fields and payroll settings prepared for the partner submission.</p>
    </div>
    <div class="grid gap-0 lg:grid-cols-[1fr_0.82fr]">
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-100 text-sm">
          <thead class="bg-slate-50 text-left text-xs font-semibold uppercase text-slate-500">
            <tr>
              <th class="px-5 py-3">Field</th>
              <th class="px-5 py-3">Value</th>
              <th class="px-5 py-3">Destination</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% [
              [ "Name", @provisioning.payload.name, "create.name" ],
              [ "Legal name", @provisioning.payload.legal_name, "create.legal_name" ],
              [ "EIN", @provisioning.payload.ein, "create.ein" ],
              [ "Billing email", @provisioning.payload.email, "create.email" ],
              [ "Phone", @provisioning.payload.phone_number.presence || "Optional", "create.phone_number" ],
              [ "Reference ID", @provisioning.payload.reference_id, "create.reference_id" ],
              [ "Pay frequency", @provisioning.payload.pay_frequency, "settings.pay_frequency" ],
              [ "Eligibility classification", @provisioning.payload.eligibility_classification, "eligibility_policy.classification" ],
              [ "Eligibility waiting period", @provisioning.payload.eligibility_waiting_period, "eligibility_policy.waiting_period" ]
            ].each do |label, value, key| %>
              <tr class="hover:bg-slate-50">
                <td class="px-5 py-4 font-semibold text-slate-950"><%= label %></td>
                <td class="break-words px-5 py-4 text-slate-600"><%= value.presence || "Missing" %></td>
                <td class="px-5 py-4 font-mono text-xs text-slate-500"><%= key %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
      <div class="border-t border-slate-100 p-5 lg:border-l lg:border-t-0">
        <p class="text-xs font-semibold uppercase text-slate-400">Employer address</p>
        <p class="mt-3 text-lg font-semibold text-slate-950"><%= @provisioning.payload.address_line_1.presence || "Missing street address" %></p>
        <p class="mt-1 text-sm text-slate-600"><%= [ @provisioning.payload.city, @provisioning.payload.state, @provisioning.payload.zipcode ].compact_blank.join(", ").presence || "City, state, and ZIP required" %></p>
        <div class="mt-5 rounded-md bg-slate-50 p-4">
          <p class="text-xs font-semibold uppercase text-slate-400">Submission mode</p>
          <p class="mt-2 text-2xl font-semibold text-slate-950"><%= @provisioning.payload.mode.humanize %></p>
          <p class="mt-2 break-all font-mono text-xs text-slate-500"><%= @provisioning.payload.endpoint %></p>
        </div>
      </div>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[1fr_1fr]">
    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Provisioning holdbacks</h2>
        <p class="text-sm text-slate-500">Blocking fields excluded from submit until legal entity or address data is repaired.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @provisioning.holdbacks.each do |holdback| %>
          <div class="p-5">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase text-slate-400"><%= holdback.field.humanize %></p>
                <h3 class="mt-2 text-base font-semibold text-slate-950"><%= holdback.reason %></h3>
              </div>
              <%= status_pill(holdback.status) %>
            </div>
            <p class="mt-2 break-all text-xs text-slate-400"><%= holdback.reason_code %></p>
          </div>
        <% end %>
        <% if @provisioning.holdbacks.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No holdbacks in the current provisioning payload.</p>
        <% end %>
      </div>
    </section>

    <section class="min-w-0 rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Employer submission activity</h2>
        <p class="text-sm text-slate-500">Submission attempts for employer create, settings updates, and eligibility policy creation.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @provisioning.request_logs.each do |log| %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0">
                <p class="font-semibold text-slate-950"><%= log.method %> <%= log.path %></p>
                <p class="mt-1 text-sm text-slate-500"><%= log.operation %> · <%= log.duration_ms || 0 %>ms</p>
                <% if log.error_class.present? %>
                  <p class="mt-1 break-all text-xs text-rose-600"><%= log.error_class %></p>
                <% end %>
              </div>
              <%= status_pill(log.error_class.present? ? "failed" : "ready") %>
            </div>
          </div>
        <% end %>
        <% if @provisioning.request_logs.empty? %>
          <p class="px-5 py-5 text-sm text-slate-500">No employer submissions have been sent yet.</p>
        <% end %>
      </div>
    </section>
  </div>
</section>
