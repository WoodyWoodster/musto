<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Musto" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Musto">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[#f7f9fc] text-[#0a2540] antialiased">
    <div class="min-h-screen lg:flex">
      <aside class="border-b border-slate-200 bg-white px-4 py-4 lg:fixed lg:inset-y-0 lg:left-0 lg:w-72 lg:border-b-0 lg:border-r">
        <div class="flex items-center justify-between lg:block">
          <%= link_to root_path, class: "flex items-center gap-3" do %>
            <span class="flex h-9 w-9 items-center justify-center rounded-md bg-[#0a2540] text-sm font-bold text-white shadow-sm">M</span>
            <span>
              <span class="block text-sm font-semibold leading-4 text-slate-950">Musto</span>
              <span class="block text-xs text-slate-500">Payroll and HR</span>
            </span>
          <% end %>
          <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold text-slate-700 lg:mt-6">
            <span class="h-1.5 w-1.5 rounded-full bg-emerald-500"></span>
            Platform workspace
          </div>
        </div>

        <nav class="mt-5 flex gap-3 overflow-x-auto pb-2 lg:block lg:max-h-[calc(100vh-9rem)] lg:space-y-6 lg:overflow-y-auto lg:pb-0">
          <div class="flex gap-2 lg:block lg:space-y-1">
            <p class="hidden px-3 text-xs font-semibold text-slate-400 lg:block">Overview</p>
            <%= nav_item("Command", root_path) %>
            <%= nav_item("Reports", reports_path) %>
            <%= nav_item("Employers", employers_path) %>
          </div>

          <div class="flex gap-2 lg:block lg:space-y-1">
            <p class="hidden px-3 text-xs font-semibold text-slate-400 lg:block">Company</p>
            <%= nav_item("Company setup", company_setup_path) %>
            <%= nav_item("Directory", people_directory_path) %>
            <%= nav_item("Documents", documents_path) %>
            <%= nav_item("Compliance", compliance_path) %>
            <%= nav_item("Workers comp", workers_comp_path) %>
            <%= nav_item("Notices", compliance_notices_path) %>
          </div>

          <div class="flex gap-2 lg:block lg:space-y-1">
            <p class="hidden px-3 text-xs font-semibold text-slate-400 lg:block">People</p>
            <%= nav_item("Workforce", workforce_path) %>
            <%= nav_item("Hiring", hiring_path) %>
            <%= nav_item("Onboarding", onboarding_path) %>
            <%= nav_item("Self service", employee_changes_path) %>
            <%= nav_item("Performance", performance_path) %>
            <%= nav_item("Training", training_path) %>
            <%= nav_item("Lifecycle", lifecycle_path) %>
          </div>

          <div class="flex gap-2 lg:block lg:space-y-1">
            <p class="hidden px-3 text-xs font-semibold text-slate-400 lg:block">Payroll</p>
            <%= nav_item("Payroll", payroll_path) %>
            <%= nav_item("Pay changes", compensation_changes_path) %>
            <%= nav_item("Compensation", compensation_path) %>
            <%= nav_item("Deductions", payroll_deductions_center_path) %>
            <%= nav_item("Garnishments", payroll_garnishments_path) %>
            <%= nav_item("Calendar", payroll_calendar_path) %>
            <%= nav_item("Funding", payroll_funding_path) %>
            <%= nav_item("Pay stubs", pay_statements_path) %>
            <%= nav_item("Year-end", year_end_tax_forms_path) %>
            <%= nav_item("Taxes", taxes_path) %>
            <%= nav_item("Tax setup", tax_agency_registrations_path) %>
          </div>

          <div class="flex gap-2 lg:block lg:space-y-1">
            <p class="hidden px-3 text-xs font-semibold text-slate-400 lg:block">Benefits</p>
            <%= nav_item("Benefits", benefits_path) %>
            <%= nav_item("Plan admin", benefits_plan_admin_path) %>
            <%= nav_item("Open enrollment", benefits_open_enrollment_path) %>
            <%= nav_item("Dependents", benefits_dependent_verifications_path) %>
            <%= nav_item("Offboarding", benefits_offboarding_path) %>
            <%= nav_item("Billing", benefits_billing_path) %>
          </div>

          <div class="flex gap-2 lg:block lg:space-y-1">
            <p class="hidden px-3 text-xs font-semibold text-slate-400 lg:block">Operations</p>
            <%= nav_item("Time off", time_off_path) %>
            <%= nav_item("PTO ledger", time_off_accruals_path) %>
            <%= nav_item("Scheduling", scheduling_path) %>
            <%= nav_item("Timesheets", timesheets_path) %>
            <%= nav_item("Expenses", expenses_path) %>
            <%= nav_item("Contractors", contractors_path) %>
            <%= nav_item("Integrations", integrations_path) %>
            <%= nav_item("Employer sync", vitable_employer_provisioning_path) %>
            <%= nav_item("Census sync", vitable_census_sync_path) %>
            <%= nav_item("Enrollment sessions", vitable_embedded_sessions_path) %>
          </div>
        </nav>
      </aside>

      <div class="min-w-0 flex-1 lg:pl-72">
        <header class="sticky top-0 z-20 border-b border-slate-200 bg-white/90 px-5 py-3 backdrop-blur-xl lg:px-8">
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-xs font-semibold text-slate-400">Musto Platform</p>
              <p class="text-sm font-medium text-slate-700">Unified HR, payroll, benefits, and compliance operations.</p>
            </div>
            <div class="flex items-center gap-2">
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">Production</span>
              <span class="rounded-full bg-[#f4f3ff] px-3 py-1 text-xs font-semibold text-[#635bff]">Admin</span>
            </div>
          </div>
        </header>

        <% if notice.present? %>
          <div class="mx-auto mt-5 max-w-7xl px-5 lg:px-8">
            <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800"><%= notice %></div>
          </div>
        <% end %>

        <main class="mx-auto max-w-7xl px-5 py-7 lg:px-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
