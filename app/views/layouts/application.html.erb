<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Musto" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Musto">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-[#f6f9fc] text-slate-950 antialiased">
    <div class="min-h-screen lg:flex">
      <aside class="border-b border-slate-200 bg-[#f7fafc]/95 px-4 py-4 lg:fixed lg:inset-y-0 lg:left-0 lg:w-72 lg:border-b-0 lg:border-r">
        <div class="flex items-center justify-between lg:block">
          <%= link_to root_path, class: "flex items-center gap-3" do %>
            <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-slate-950 text-sm font-bold text-white shadow-sm">M</span>
            <span>
              <span class="block text-sm font-semibold leading-4 text-slate-950">Musto</span>
              <span class="block text-xs text-slate-500">Benefits OS</span>
            </span>
          <% end %>
          <div class="rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold text-emerald-700 lg:mt-6 lg:inline-flex">
            Ruby 4 · Rails 8.1
          </div>
        </div>

        <nav class="mt-5 grid grid-cols-2 gap-2 lg:grid-cols-1">
          <%= nav_item("Command", root_path, accent: "bg-sky-500") %>
          <%= nav_item("Company", company_setup_path, accent: "bg-slate-500") %>
          <%= nav_item("Workforce", workforce_path, accent: "bg-emerald-500") %>
          <%= nav_item("Hiring", hiring_path, accent: "bg-indigo-500") %>
          <%= nav_item("Self Service", employee_changes_path, accent: "bg-sky-500") %>
          <%= nav_item("Performance", performance_path, accent: "bg-violet-500") %>
          <%= nav_item("Training", training_path, accent: "bg-emerald-500") %>
          <%= nav_item("Lifecycle", lifecycle_path, accent: "bg-blue-500") %>
          <%= nav_item("Onboarding", onboarding_path, accent: "bg-cyan-500") %>
          <%= nav_item("Documents", documents_path, accent: "bg-sky-500") %>
          <%= nav_item("Time Off", time_off_path, accent: "bg-violet-500") %>
          <%= nav_item("Scheduling", scheduling_path, accent: "bg-teal-500") %>
          <%= nav_item("Timesheets", timesheets_path, accent: "bg-lime-500") %>
          <%= nav_item("Expenses", expenses_path, accent: "bg-orange-500") %>
          <%= nav_item("Contractors", contractors_path, accent: "bg-pink-500") %>
          <%= nav_item("Compensation", compensation_path, accent: "bg-fuchsia-500") %>
          <%= nav_item("Payroll", payroll_path, accent: "bg-indigo-500") %>
          <%= nav_item("Deductions", payroll_deductions_center_path, accent: "bg-rose-500") %>
          <%= nav_item("Calendar", payroll_calendar_path, accent: "bg-sky-500") %>
          <%= nav_item("Funding", payroll_funding_path, accent: "bg-green-500") %>
          <%= nav_item("Pay Stubs", pay_statements_path, accent: "bg-purple-500") %>
          <%= nav_item("Taxes", taxes_path, accent: "bg-teal-500") %>
          <%= nav_item("Benefits", benefits_path, accent: "bg-cyan-500") %>
          <%= nav_item("Open Enrollment", benefits_open_enrollment_path, accent: "bg-blue-500") %>
          <%= nav_item("Billing", benefits_billing_path, accent: "bg-emerald-500") %>
          <%= nav_item("Reports", reports_path, accent: "bg-amber-500") %>
          <%= nav_item("Compliance", compliance_path, accent: "bg-rose-500") %>
          <%= nav_item("Integrations", integrations_path, accent: "bg-amber-500") %>
          <%= nav_item("Census Sync", vitable_census_sync_path, accent: "bg-cyan-500") %>
          <%= nav_item("Embed Sessions", vitable_embedded_sessions_path, accent: "bg-emerald-500") %>
          <%= nav_item("Employers", employers_path, accent: "bg-slate-500") %>
        </nav>

        <div class="mt-6 hidden rounded-lg border border-slate-200 bg-white p-4 shadow-sm lg:block">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-400">Integration mode</p>
          <p class="mt-2 text-sm font-semibold text-slate-950">Vitable Connect</p>
          <p class="mt-1 text-xs leading-5 text-slate-500">Webhook-first event ingestion with fresh resource fetches once API credentials are configured.</p>
        </div>
      </aside>

      <div class="min-w-0 flex-1 lg:pl-72">
        <header class="sticky top-0 z-20 border-b border-slate-200 bg-white/85 px-5 py-3 backdrop-blur-xl lg:px-8">
          <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">People · Payroll · Benefits</p>
              <p class="text-sm font-medium text-slate-700">Operational command center for pushing the Vitable integration surface.</p>
            </div>
            <div class="flex items-center gap-2">
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">Sandbox-ready</span>
              <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">CQRS + DTO</span>
            </div>
          </div>
        </header>

        <% if notice.present? %>
          <div class="mx-auto mt-5 max-w-7xl px-5 lg:px-8">
            <div class="rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-800"><%= notice %></div>
          </div>
        <% end %>

        <main class="mx-auto max-w-7xl px-5 py-7 lg:px-8">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
