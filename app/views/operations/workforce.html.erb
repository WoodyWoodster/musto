<section class="space-y-7">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-emerald-700">Workforce</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">People operations</h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">Roster intelligence, onboarding progress, documents, departments, and locations for <%= @workforce[:employer]&.name || "your employer portfolio" %>.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Onboarding center", onboarding_path, class: "rounded-md bg-slate-950 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      <span class="rounded-md border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm"><%= @workforce[:employees].count %> employees</span>
      <span class="rounded-md border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm"><%= @workforce[:open_onboarding_count] %> open tasks</span>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-3">
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-slate-500">Departments</p>
      <p class="mt-3 text-3xl font-semibold"><%= @workforce[:departments].count %></p>
      <p class="mt-1 text-sm text-slate-500">budgeted teams</p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-slate-500">Locations</p>
      <p class="mt-3 text-3xl font-semibold"><%= @workforce[:locations].count %></p>
      <p class="mt-1 text-sm text-slate-500">including remote hubs</p>
    </div>
    <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-sm text-slate-500">Documents needing attention</p>
      <p class="mt-3 text-3xl font-semibold"><%= @workforce[:documents_attention_count] %></p>
      <p class="mt-1 text-sm text-slate-500">pending or expired</p>
    </div>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="flex items-center justify-between border-b border-slate-100 px-5 py-4">
      <div>
        <h2 class="text-base font-semibold text-slate-950">Roster</h2>
        <p class="text-sm text-slate-500">Compensation, benefits, and onboarding readiness by employee.</p>
      </div>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">Payroll audit view</span>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Team</th>
            <th class="px-5 py-3">Location</th>
            <th class="px-5 py-3">Compensation</th>
            <th class="px-5 py-3">Benefits</th>
            <th class="px-5 py-3">Onboarding</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @workforce[:employees].each do |employee| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4">
                <%= link_to employee.full_name, employee_path(employee.id), class: "font-semibold text-slate-950 hover:text-cyan-700" %>
                <p class="text-xs text-slate-500"><%= employee.title.presence || "Role pending" %> · <%= employee.email %></p>
              </td>
              <td class="px-5 py-4 text-slate-600"><%= employee.department_name || "Unassigned" %></td>
              <td class="px-5 py-4 text-slate-600"><%= employee.work_location_name || "Unassigned" %></td>
              <td class="px-5 py-4">
                <p class="font-medium text-slate-950"><%= money_cents(employee.compensation_cents) %></p>
                <p class="text-xs text-slate-500"><%= employee.pay_type.humanize %></p>
              </td>
              <td class="px-5 py-4"><%= status_pill(employee.benefits_status) %></td>
              <td class="px-5 py-4"><%= status_pill(employee.onboarding_status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
    <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Onboarding queue</h2>
        <p class="text-sm text-slate-500">Tasks can be completed directly from the workflow.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @workforce[:onboarding_tasks].first(8).each do |task| %>
          <div class="grid gap-4 px-5 py-4 md:grid-cols-[1fr_auto] md:items-center">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <p class="font-semibold text-slate-950"><%= task.title %></p>
                <%= status_pill(task.status) %>
              </div>
              <p class="mt-1 text-sm text-slate-500"><%= task.employee_name %> · <%= task.category.humanize %> · due <%= task.due_on.strftime("%b %-d") %></p>
            </div>
            <% unless task.complete? %>
              <%= button_to "Complete", complete_onboarding_task_path(task.id), method: :post, class: "rounded-md bg-slate-950 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Departments and locations</h2>
        <p class="text-sm text-slate-500">Operating structure for payroll taxes, compliance, and manager workflows.</p>
      </div>
      <div class="grid divide-y divide-slate-100 md:grid-cols-2 md:divide-x md:divide-y-0">
        <div class="p-5">
          <h3 class="text-sm font-semibold text-slate-950">Teams</h3>
          <div class="mt-4 space-y-3">
            <% @workforce[:departments].each do |department| %>
              <div class="rounded-md border border-slate-200 p-3">
                <div class="flex justify-between gap-4">
                  <p class="font-medium text-slate-950"><%= department.name %></p>
                  <span class="text-xs font-semibold text-slate-400"><%= department.code %></span>
                </div>
                <p class="mt-1 text-xs text-slate-500"><%= department.employee_count %> people · <%= money_cents(department.budget_cents) %> budget</p>
              </div>
            <% end %>
          </div>
        </div>
        <div class="p-5">
          <h3 class="text-sm font-semibold text-slate-950">Work locations</h3>
          <div class="mt-4 space-y-3">
            <% @workforce[:locations].each do |location| %>
              <div class="rounded-md border border-slate-200 p-3">
                <div class="flex justify-between gap-4">
                  <p class="font-medium text-slate-950"><%= location.name %></p>
                  <%= status_pill(location.status) %>
                </div>
                <p class="mt-1 text-xs text-slate-500"><%= location.city.presence || "Distributed" %>, <%= location.country %> · <%= location.employee_count %> people</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </section>
  </div>
</section>
