<section class="space-y-7">
  <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
    <div>
      <p class="text-sm font-semibold uppercase tracking-[0.18em] text-rose-700">Compliance</p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight text-slate-950">Risk and policy center</h1>
      <p class="mt-2 max-w-3xl text-sm leading-6 text-slate-600">Resolve compliance cases, keep documents current, and review time-off requests from the same operational queue.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Time off center", time_off_path, class: "rounded-md bg-slate-950 px-4 py-3 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
      <span class="rounded-md border border-slate-200 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm"><%= @compliance[:open_case_count] %> open cases</span>
    </div>
  </div>

  <div class="grid gap-4 md:grid-cols-4">
    <% [
      ["Open cases", @compliance[:open_case_count], "bg-rose-500"],
      ["Urgent cases", @compliance[:urgent_case_count], "bg-orange-500"],
      ["Docs attention", @compliance[:documents].count, "bg-amber-500"],
      ["Time off pending", @compliance[:pending_time_off_count], "bg-cyan-500"]
    ].each do |label, value, accent| %>
      <div class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="flex items-center justify-between">
          <p class="text-sm text-slate-500"><%= label %></p>
          <span class="h-2.5 w-2.5 rounded-full <%= accent %>"></span>
        </div>
        <p class="mt-3 text-3xl font-semibold"><%= value %></p>
      </div>
    <% end %>
  </div>

  <div class="grid gap-6 xl:grid-cols-[1fr_0.9fr]">
    <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Compliance cases</h2>
        <p class="text-sm text-slate-500">Open operational risk items with severity and due dates.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @compliance[:cases].each do |item| %>
          <div class="grid gap-4 px-5 py-4 md:grid-cols-[1fr_auto] md:items-center">
            <div>
              <div class="flex flex-wrap items-center gap-2">
                <p class="font-semibold text-slate-950"><%= item.kind.humanize %></p>
                <%= status_pill(item.severity) %>
                <%= status_pill(item.status) %>
              </div>
              <p class="mt-1 text-sm text-slate-500"><%= item.employee_name || "Employer-wide" %> · due <%= item.due_on&.strftime("%b %-d") || "unscheduled" %></p>
              <p class="mt-2 text-sm text-slate-600"><%= item.description %></p>
            </div>
            <% unless item.resolved? %>
              <%= button_to "Resolve", resolve_compliance_case_path(item.id), method: :post, class: "rounded-md bg-slate-950 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>

    <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
      <div class="border-b border-slate-100 px-5 py-4">
        <h2 class="text-base font-semibold text-slate-950">Time off review</h2>
        <p class="text-sm text-slate-500">Approve or deny requests that affect payroll and staffing.</p>
      </div>
      <div class="divide-y divide-slate-100">
        <% @compliance[:time_off_requests].first(8).each do |request| %>
          <div class="px-5 py-4">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="font-semibold text-slate-950"><%= request.employee_name %></p>
                <p class="mt-1 text-sm text-slate-500"><%= request.policy_name %> · <%= request.starts_on.strftime("%b %-d") %> - <%= request.ends_on.strftime("%b %-d") %> · <%= request.hours.to_i %>h</p>
                <p class="mt-2 text-sm text-slate-600"><%= request.reason.presence || "No reason provided" %></p>
              </div>
              <%= status_pill(request.status) %>
            </div>
            <% if request.requested? %>
              <div class="mt-4 flex gap-2">
                <%= button_to "Approve", approve_time_off_request_path(request.id), method: :post, class: "rounded-md bg-emerald-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-emerald-700" %>
                <%= button_to "Deny", deny_time_off_request_path(request.id), method: :post, class: "rounded-md border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:border-slate-300" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="border-b border-slate-100 px-5 py-4">
      <h2 class="text-base font-semibold text-slate-950">Document exceptions</h2>
      <p class="text-sm text-slate-500">Documents that require collection, renewal, or audit review.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-100 text-sm">
        <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
          <tr>
            <th class="px-5 py-3">Employee</th>
            <th class="px-5 py-3">Document</th>
            <th class="px-5 py-3">Type</th>
            <th class="px-5 py-3">Expires</th>
            <th class="px-5 py-3">Status</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @compliance[:documents].each do |document| %>
            <tr class="hover:bg-slate-50">
              <td class="px-5 py-4 font-medium text-slate-950"><%= document.employee_name %></td>
              <td class="px-5 py-4 text-slate-600"><%= document.title %></td>
              <td class="px-5 py-4 text-slate-600"><%= document.document_type.humanize %></td>
              <td class="px-5 py-4 text-slate-600"><%= document.expires_on&.strftime("%b %-d, %Y") || "No expiry" %></td>
              <td class="px-5 py-4"><%= status_pill(document.status) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
